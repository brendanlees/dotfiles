{{- /* zsh + tmux plugins — shell-side only; Windows uses PowerShell, no tmux. */ -}}
{{- if ne .chezmoi.os "windows" }}
[".local/share/zsh/plugins/zsh-autosuggestions"]
type = "archive"
url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/*.circleci",
  "*/test/**",
  "*/tests/**",
  "*/spec/**",
  "**/*.zwc",
]

[".local/share/zsh/plugins/zsh-syntax-highlighting"]
type = "archive"
url = "https://github.com/zsh-users/zsh-syntax-highlighting/archive/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/test/**",
  "*/tests/**",
  "*/test-data/**",
  "*/highlighters/*/test-data/**",
  "*/spec/**",
  "**/*.zwc",
]

[".local/share/zsh/plugins/zsh-completions"]
type = "git-repo"
url = "https://github.com/zsh-users/zsh-completions.git"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/test/**",
  "*/tests/**",
  "*/spec/**",
  "**/*.zwc",
]

[".local/share/zsh/plugins/fzf-tab"]
type = "git-repo"
url = "https://github.com/Aloxaf/fzf-tab"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/test/**",
  "*/tests/**",
  "*/spec/**",
  "*/images/**",
  "**/*.zwc",
]

[".config/tmux/plugins/tpm"]
type = "git-repo"
url = "https://github.com/tmux-plugins/tpm"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/test/**",
  "*/tests/**",
  "*/spec/**",
  "*/docs/**",
  "*/bindings/**",
  "**/*.zwc",
]
{{- end }}

{{- /* Windows installs nerd fonts via scoop (matthewjberger/scoop-nerd-fonts),
       which handles font-registry registration. Only darwin/linux drop ttf
       files directly via chezmoi-external. */ -}}
{{- if and .personal (not .headless) (or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux")) }}
{{-   $fontDir := "" }}
{{-   if eq .chezmoi.os "darwin" }}
{{-     $fontDir = "Library/Fonts" }}
{{-   else if eq .chezmoi.os "linux" }}
{{-     $fontDir = ".local/share/fonts" }}
{{-   end }}

["{{ $fontDir }}/{{ .nerd_font }}"]
type = "archive"
url = "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/{{ .nerd_font }}.tar.xz"
exact = true
refreshPeriod = "168h"
include = ["{{ .nerd_font }}NerdFontMono-*.ttf"]
{{- end }}

{{- if not .ephemeral }}
{{- /* nvim path: ~/.config/nvim on darwin/linux, ~/AppData/Local/nvim on windows */ -}}
{{- $nvimPath := ".config/nvim" }}
{{- if eq .chezmoi.os "windows" }}{{ $nvimPath = "AppData/Local/nvim" }}{{ end }}
["{{ $nvimPath }}"]
type = "archive"
url = "https://github.com/brendanlees/astronvim-config/archive/main.tar.gz"
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/test/**",
  "*/tests/**",
  "*/spec/**",
  "**/*.zwc",
  "**/lazy-lock.json",
]
{{- end }}

{{- if .personal }}
[".claude"]
type = "git-repo"
url = "https://gitea.lab.brendans.cloud/xbxd/claude-config.git"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]
{{- end }}

