# to update run 'chezmoi apply -R' to refresh externals

[".cli-plugins/zsh/zsh-autosuggestions"]
type = "archive"
url = "https://github.com/zsh-users/zsh-autosuggestions/archive/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
  "*/*.circleci",
]

[".cli-plugins/zsh/zsh-syntax-highlighting"]
type = "archive"
url = "https://github.com/zsh-users/zsh-syntax-highlighting/archive/master.tar.gz"
exact = true
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]

[".cli-plugins/zsh/zsh-completions"]
type = "git-repo"
url = "https://github.com/zsh-users/zsh-completions.git"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]

[".cli-plugins/fzf/fzf-tab"]
type = "git-repo"
url = "https://github.com/Aloxaf/fzf-tab"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]

[".cli-plugins/fzf/fzf-git.sh"]
type = "file"
url = "https://github.com/junegunn/fzf-git.sh/raw/main/fzf-git.sh"
exact = true
stripComponents = 1
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]

[".tmux/plugins/tpm"]
type = "git-repo"
url = "https://github.com/tmux-plugins/tpm"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]

{{- if not .ephemeral }}
[".config/nvim"]
type = "git-repo"
url = "https://github.com/brendanlees/astronvim-config"
refreshPeriod = "168h"
exclude = [
  "*/.editorconfig",
  "*/.gitattributes",
  "*/.github",
  "*/.gitignore",
  "*/*.md",
]
{{- end }}

{{/* ─── fonts ─── */}}
{{- if not .ephemeral }}
{{- range .fonts_installed }}
{{- $localZip := joinPath $.chezmoi.sourceDir "fonts" (printf "%s.zip" .) }}
{{ if eq $.chezmoi.os "darwin" -}}
["Library/Fonts/NerdFonts/{{ . }}"]
{{- else -}}
[".local/share/fonts/NerdFonts/{{ . }}"]
{{- end }}
type = "archive"
refreshPeriod = "168h"
{{ if stat $localZip -}}
url = "file://{{ $localZip }}"
{{- else -}}
url = "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/{{ . }}.zip"
{{- end }}
{{- end }}
{{- end }}
