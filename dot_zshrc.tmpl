# ------------------------------------------
# helpers
# ------------------------------------------

# Cache a tool's shell-init output to disk and re-eval from cache. Re-runs the
# tool only when its binary is newer than the cache. Usage:
#   _cached_eval <tag> <bin> <init-cmd…>
_cached_eval() {
  local tag=$1 bin=$2; shift 2
  local cache="$XDG_CACHE_HOME/zsh/init/${tag}.zsh"
  local binpath=$commands[$bin]
  [[ -n $binpath ]] || return
  if [[ ! -s $cache || $binpath -nt $cache ]]; then
    mkdir -p "${cache:h}"
    "$@" > "$cache"
  fi
  source "$cache"
}

