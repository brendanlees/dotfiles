# ------------------------------------------
# bindings
# ------------------------------------------

# at the end to override any range bindings (fzf, tmux, compinit)

# --- lines ---
# navigate lines using ctrl+a and ctrl+e
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line

# Make accidental backspace/left-arrow at the start of the prompt a no-op
# instead of emitting BEL. This preserves real terminal bells from
# tmux/agent hooks.
_no_bell_backward_delete_char() {
  if (( CURSOR > 0 )); then
    zle .backward-delete-char
  fi
}
_no_bell_backward_char() {
  if (( CURSOR > 0 )); then
    zle .backward-char
  fi
}
zle -N no-bell-backward-delete-char _no_bell_backward_delete_char
zle -N no-bell-backward-char _no_bell_backward_char
for _keymap in viins emacs; do
  bindkey -M $_keymap '^?' no-bell-backward-delete-char
  bindkey -M $_keymap '^H' no-bell-backward-delete-char
  bindkey -M $_keymap '^[[D' no-bell-backward-char
  bindkey -M $_keymap '^[OD' no-bell-backward-char
done
bindkey -M vicmd '^[[D' no-bell-backward-char
bindkey -M vicmd '^[OD' no-bell-backward-char
unset _keymap

# Ctrl+X Ctrl+E opens current command line in $EDITOR (nvim), save+quit
# returns edited line to prompt. Matches the bash convention + the
# Windows pwsh profile binding for cross-platform muscle memory.
autoload -U edit-command-line
zle -N edit-command-line
bindkey '^X^E' edit-command-line

# --- history ---
# navigate zsh history using ctrl+p/n,k/j
bindkey '^P' history-search-backward
bindkey '^N' history-search-forward
bindkey '^k' up-line-or-search
bindkey '^j' down-line-or-search

# --- clipboard ---
# pipe stdin to the platform clipboard
_clip_copy() {
{{- if eq .chezmoi.os "darwin" }}
  pbcopy
{{- else if eq .chezmoi.os "linux" }}
  local encoded
  encoded=$(base64 | tr -d '\n')
  printf "\033]52;c;%s\a" "$encoded" > /dev/tty
{{- end }}
}

# copy current command to clipboard
copy-command() {
  print -rn -- "$BUFFER" | _clip_copy
  zle -M "Copied to clipboard"
}
zle -N copy-command
bindkey '^Xc' copy-command

# copy current working directory to clipboard
alias cpwd='pwd | tr -d "\n" | _clip_copy'

# --- navigation combos ---
# cd and ls
cx() { cd "$@" && ls; } 

# Use fd when available (faster, skips hidden + .gitignore by default);
# fall back to find with the equivalent hidden-skipping pattern.
_pick_d() {
  if (( $+commands[fd] )); then fd -t d
  else find . -type d -not -path '*/.*'
  fi
}
_pick_f() {
  if (( $+commands[fd] )); then fd -t f
  else find . -type f -not -path '*/.*'
  fi
}

# find dir and ls
fcd() { cd "$(_pick_d | fzf)" && ls; }

# find file and copy to clipboard
f() {
  echo "$(_pick_f | fzf)" | \
{{- if eq .chezmoi.os "darwin" }}
    pbcopy
{{- else }}
    xclip -selection clipboard
{{- end }}
}

# find and open in nvim
fv() { nvim "$(_pick_f | fzf)" }

# ------------------------------------------
# moshi
# ------------------------------------------

moshi() {
  local dir="${1:-$PWD}"
  if [[ ! -d "$dir" ]]; then
    echo "Directory not found: $dir" >&2
    return 1
  fi

  local abs
  abs="$(cd "$dir" && pwd)"

  local session
  session="$(basename "$abs" | tr -cs '[:alnum:]_-' '-')"
  session="${session#-}"
  session="${session%-}"
  [[ -n "$session" ]] || session="main"

  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$abs" -n agent
    tmux new-window -t "$session":2 -c "$abs" -n review
    tmux new-window -t "$session":3 -c "$abs" -n tests
    tmux new-window -t "$session":4 -c "$abs" -n servers
    tmux new-window -t "$session":5 -c "$abs" -n misc
  fi

  tmux attach -t "$session"
}

