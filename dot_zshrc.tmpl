export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export ESPANSO_CONFIG_DIR="$XDG_CONFIG_HOME/espanso"

# ------------------------------------------
# aliases / replacements
# ------------------------------------------

source "$XDG_CONFIG_HOME/zsh/aliases.zsh"

# ------------------------------------------
# api tokens
# ------------------------------------------

{{- if .personal }}
if command -v gh &>/dev/null && gh auth token &>/dev/null 2>&1; then
  export GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token)
  export GITHUB_TOKEN="$GITHUB_PERSONAL_ACCESS_TOKEN"
fi
{{- else }}
  export GITHUB_TOKEN="$GITHUB_PERSONAL_ACCESS_TOKEN"
{{- end }}

# ------------------------------------------
# vim
# ------------------------------------------

export EDITOR=nvim
set -o vi
bindkey jj vi-cmd-mode

# ------------------------------------------
# zsh plugins
# ------------------------------------------

# load zsh-syntax-highlighting
source "$XDG_DATA_HOME/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# load zsh-completions
fpath=("$XDG_DATA_HOME/zsh/plugins/zsh-completions/" $fpath)

# completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --tree --color=always $realpath | head -200'
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:*' prefix '│'
zstyle ':fzf-tab:*' group-colors \
  $'\033[38;2;118;159;240m' \
  $'\033[38;2;115;218;202m' \
  $'\033[38;2;187;154;247m' \
  $'\033[38;2;158;206;106m'

# load zsh-autosuggestions
source "$XDG_DATA_HOME/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"

# autosuggestions history config
export HISTSIZE=10000
export HISTFILE="$XDG_STATE_HOME/zsh/history"
export SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups


# ------------------------------------------
# mise
# ------------------------------------------

export PATH=$HOME/.local/bin:$PATH
eval "$(mise activate zsh)"

# ------------------------------------------
# starship
# ------------------------------------------

# start starship prompt
eval "$(starship init zsh)"
export STARSHIP_CONFIG=~/.config/starship/starship.toml

# ------------------------------------------
# fzf 
# ------------------------------------------

# set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

# load fzf-tab script
mkdir -p "$XDG_CACHE_HOME/zsh" 2>/dev/null
autoload -U compinit; compinit -d "$XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION" -u
source "$XDG_DATA_HOME/zsh/plugins/fzf-tab/fzf-tab.plugin.zsh"

# ------------------------------------------
# carapace 
# ------------------------------------------

if command -v carapace &>/dev/null; then
  source <(carapace _carapace zsh)
fi

{{- if .homelab }}
# ------------------------------------------
# homelab
# ------------------------------------------

if [[ -d /boot/dietpi ]]; then
  export PATH=/usr/bin:/boot/dietpi:/bin:/usr/sbin:/sbin:$PATH
  /boot/dietpi/dietpi-login
fi
{{- end }}

{{- if and .personal (eq .chezmoi.os "darwin") }}
# ------------------------------------------
# mac
# ------------------------------------------

# brew tweaks
export PATH=/opt/homebrew/bin:$PATH
export HOMEBREW_NO_ENV_HINTS=1

# dumb/fun stuff
alias matrix='osascript -e "tell application \"System Events\" to key code 36 using {command down}" && { [[ -n $TMUX ]] && tmux new-window cmatrix -C cyan || tmux new-session cmatrix -C cyan; }'

{{- end }}

# ------------------------------------------
# git
# ------------------------------------------

# worktrunk
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# ------------------------------------------
# bindings
# ------------------------------------------

# at the end to override any range bindings (fzf, tmux, compinit)

# --- lines ---
# navigate lines using ctrl+a and ctrl+e
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line

# --- history ---
# navigate zsh history using ctrl+p/n,k/j
bindkey '^P' history-search-backward
bindkey '^N' history-search-forward
bindkey '^k' up-line-or-search
bindkey '^j' down-line-or-search

# --- clipboard ---
# copy current command to clipboard
copy-command() {
{{- if eq .chezmoi.os "darwin" }}
  echo -n $BUFFER | pbcopy
{{- else if eq .chezmoi.os "linux" }}
  local encoded=$(printf '%s' "$BUFFER" | base64 | tr -d '\n')
  printf "\033]52;c;%s\a" "$encoded" > /dev/tty
{{- end }}
  zle -M "Copied to clipboard"
}
zle -N copy-command
bindkey '^Xc' copy-command

# --- navigation combos ---
# cd and ls
cx() { cd "$@" && ls; } 

# find dir and ls
fcd() { cd "$(find . -type d -not -path '*/.*' | fzf)" && ls; } 

# find file and copy to clipboard
f() {
  echo "$(find . -type f -not -path '*/.*' | fzf)" | \
{{- if eq .chezmoi.os "darwin" }}
    pbcopy
{{- else }}
    xclip -selection clipboard
{{- end }}
}

# find and open in nvim
fv() { nvim "$(find . -type f -not -path '*/.*' | fzf)" }

# ------------------------------------------
# moshi
# ------------------------------------------

moshi() {
  local dir="${1:-$PWD}"
  if [[ ! -d "$dir" ]]; then
    echo "Directory not found: $dir" >&2
    return 1
  fi

  local abs
  abs="$(cd "$dir" && pwd)"

  local session
  session="$(basename "$abs" | tr -cs '[:alnum:]_-' '-')"
  session="${session#-}"
  session="${session%-}"
  [[ -n "$session" ]] || session="main"

  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$abs" -n agent
    tmux new-window -t "$session":2 -c "$abs" -n review
    tmux new-window -t "$session":3 -c "$abs" -n tests
    tmux new-window -t "$session":4 -c "$abs" -n servers
    tmux new-window -t "$session":5 -c "$abs" -n misc
  fi

  tmux attach -t "$session"
}

# ------------------------------------------
# zoxide
# ------------------------------------------
# !NOTE must be last

if [[ -o interactive ]] && command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init --cmd cd zsh)"
fi
