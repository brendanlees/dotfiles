#!/usr/bin/env bash
# theme — switch the global chezmoi theme and live-reload running apps.
#
# Usage:
#   theme                     # interactive picker (gum choose)
#   theme <theme-key>         # switch directly (e.g. tokyonight-night)
#   theme --list              # print available themes
#   theme --current           # print currently active theme
#
# Theme keys are discovered from ~/.local/share/chezmoi/.chezmoidata/themes.yml.

set -euo pipefail

CHEZMOI_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
THEMES_YML="$CHEZMOI_DIR/.chezmoidata/themes.yml"
DEFAULTS_YML="$CHEZMOI_DIR/.chezmoidata/defaults.yml"
# Host-local overlay: chezmoi merges .chezmoidata/*.yml lexicographically, so
# local.yml beats defaults.yml. Gitignored to keep theme switches out of git.
LOCAL_YML="$CHEZMOI_DIR/.chezmoidata/local.yml"

if [[ ! -f "$THEMES_YML" ]]; then
  echo "error: $THEMES_YML not found" >&2
  exit 1
fi
if [[ ! -f "$DEFAULTS_YML" ]]; then
  echo "error: $DEFAULTS_YML not found" >&2
  exit 1
fi

# Parse top-level theme keys (lines like "  tokyonight-night:" under "themes:")
mapfile -t VALID_THEMES < <(
  awk '
    /^themes:/        { in_themes = 1; next }
    in_themes && /^[^ ]/ { in_themes = 0 }
    in_themes && /^  [a-z][-a-z0-9_]*:[[:space:]]*$/ {
      gsub(/[: ]/, "")
      print
    }
  ' "$THEMES_YML"
)

current_theme() {
  # local.yml wins if it has a theme line; otherwise fall back to defaults.yml.
  if [[ -f "$LOCAL_YML" ]]; then
    local override
    override="$(awk -F'[:[:space:]"]+' '/^theme:/ { print $2; exit }' "$LOCAL_YML")"
    if [[ -n "$override" ]]; then
      printf '%s\n' "$override"
      return
    fi
  fi
  awk -F'[:[:space:]"]+' '/^theme:/ { print $2 }' "$DEFAULTS_YML"
}

list_themes() {
  local current
  current="$(current_theme)"
  for t in "${VALID_THEMES[@]}"; do
    if [[ "$t" == "$current" ]]; then
      printf "  %s (active)\n" "$t"
    else
      printf "  %s\n" "$t"
    fi
  done
}

is_valid() {
  local target="$1"
  for t in "${VALID_THEMES[@]}"; do
    [[ "$t" == "$target" ]] && return 0
  done
  return 1
}

# ---- arg handling ---------------------------------------------------------

case "${1:-}" in
  -h|--help)
    sed -n '2,9p' "$0" | sed 's/^# \?//'
    exit 0
    ;;
  --list|-l)
    list_themes
    exit 0
    ;;
  --current|-c)
    current_theme
    exit 0
    ;;
esac

CURRENT="$(current_theme)"
TARGET="${1:-}"

if [[ -z "$TARGET" ]]; then
  if command -v gum >/dev/null 2>&1; then
    TARGET="$(printf '%s\n' "${VALID_THEMES[@]}" | gum choose --header "Select theme (current: $CURRENT)")"
  else
    echo "gum not installed; pick one of:" >&2
    printf '  %s\n' "${VALID_THEMES[@]}" >&2
    exit 1
  fi
fi

[[ -z "$TARGET" ]] && { echo "no theme selected" >&2; exit 1; }

if ! is_valid "$TARGET"; then
  echo "error: '$TARGET' is not a known theme" >&2
  echo "available:" >&2
  printf '  %s\n' "${VALID_THEMES[@]}" >&2
  exit 1
fi

if [[ "$TARGET" == "$CURRENT" ]]; then
  echo "theme is already '$TARGET' — nothing to do"
  exit 0
fi

# ---- swap & apply ---------------------------------------------------------

echo ":: switching $CURRENT → $TARGET"

# Write to local.yml so theme switches don't pollute tracked defaults.yml.
# Cases:
#   - file missing       → create with single theme: line
#   - has theme: line    → in-place sed (BSD compatible)
#   - missing theme: line → append theme: line
if [[ ! -f "$LOCAL_YML" ]]; then
  printf 'theme: "%s"\n' "$TARGET" > "$LOCAL_YML"
elif grep -q '^theme:' "$LOCAL_YML"; then
  sed -i.bak -E "s|^theme:.*$|theme: \"$TARGET\"|" "$LOCAL_YML"
  rm -f "${LOCAL_YML}.bak"
else
  printf 'theme: "%s"\n' "$TARGET" >> "$LOCAL_YML"
fi

# unlock bw before apply so chezmoi can resolve bitwardenFields
if command -v bw >/dev/null 2>&1 && bw status 2>/dev/null | grep -q '"status":"locked"'; then
  echo ":: bw vault locked — unlocking for chezmoi apply"
  BW_SESSION=$(bw unlock --raw) && export BW_SESSION \
    || echo "warn: bw unlock failed; bw-backed templates will error" >&2
fi

echo ":: chezmoi apply"
chezmoi apply --source "$CHEZMOI_DIR" -v

# ---- tmux plugin install (idempotent) -------------------------------------

TPM_INSTALL="$HOME/.config/tmux/plugins/tpm/bin/install_plugins"
if [[ -x "$TPM_INSTALL" ]] && pgrep -x tmux >/dev/null 2>&1; then
  echo ":: tpm install_plugins"
  "$TPM_INSTALL" >/dev/null || echo "warn: tpm install_plugins failed" >&2
fi

# ---- live reload ----------------------------------------------------------

# tmux — re-source config + refresh server env so subprocesses launched via
# run-shell (sesh picker, popups, etc.) inherit the new theme-driven values
# instead of whatever was captured when the tmux server first started.
if command -v tmux >/dev/null 2>&1 && pgrep -x tmux >/dev/null 2>&1; then
  echo ":: tmux source-file + setenv"
  for socket in $(tmux ls -F '#{socket_path}' 2>/dev/null | sort -u); do
    tmux -S "$socket" source-file "$HOME/.config/tmux/tmux.conf" 2>/dev/null || true
    tmux -S "$socket" setenv -g FZF_DEFAULT_OPTS_FILE "$HOME/.config/fzf/opts" 2>/dev/null || true
    tmux -S "$socket" setenv -gu FZF_DEFAULT_OPTS 2>/dev/null || true
  done
fi

# ghostty — trigger its reload_config keybind (cmd+shift+,)
if pgrep -xq ghostty 2>/dev/null; then
  echo ":: ghostty reload_config"
  osascript <<'OSA' >/dev/null 2>&1 || true
tell application "Ghostty" to activate
delay 0.15
tell application "System Events" to keystroke "," using {command down, shift down}
OSA
fi

# yabai borders — SIGUSR1 reload
if pgrep -xq borders 2>/dev/null; then
  echo ":: borders reload"
  pkill -USR1 borders 2>/dev/null || true
fi

# nvim — push colorscheme to every running instance via its auto-listen socket.
# Each nvim creates a server at $XDG_RUNTIME_DIR/nvim.<pid>.0 (linux) or
# /tmp/nvim.$USER/<rand>/0 (macos); --remote-send into a <Cmd> mapping avoids
# clobbering the user's current mode (insert / cmdline / etc).
if command -v nvim >/dev/null 2>&1; then
  NVIM_NEW_CS="$(awk -F'"' '/colorscheme =/ {print $2; exit}' "$HOME/.config/chezmoi-theme/active.lua" 2>/dev/null || true)"
  NVIM_NEW_BG="$(awk -F'"' '/background =/ {print $2; exit}' "$HOME/.config/chezmoi-theme/active.lua" 2>/dev/null || true)"
  if [[ -n "$NVIM_NEW_CS" ]]; then
    NVIM_SOCKETS=( $(find /tmp/nvim.$USER -maxdepth 2 -name '0' -type s 2>/dev/null) $(find "${XDG_RUNTIME_DIR:-/tmp}" -maxdepth 1 -name 'nvim.*.0' -type s 2>/dev/null) )
    if (( ${#NVIM_SOCKETS[@]} > 0 )); then
      echo ":: nvim colorscheme → $NVIM_NEW_CS (${#NVIM_SOCKETS[@]} instance(s))"
      for sock in "${NVIM_SOCKETS[@]}"; do
        nvim --server "$sock" --remote-send "<Cmd>set background=${NVIM_NEW_BG:-dark}<CR><Cmd>colorscheme ${NVIM_NEW_CS}<CR>" 2>/dev/null || true
      done
    fi
  fi
fi

# espanso — restart so the new colors apply
if pgrep -xq espanso 2>/dev/null && command -v espanso >/dev/null 2>&1; then
  echo ":: espanso restart"
  espanso restart >/dev/null 2>&1 || true
fi

# ---- manual-restart reminder ----------------------------------------------

cat <<'EOF'

:: restart these apps manually to pick up the new theme:
   - btop
   - mactop
   - bat (next invocation reads new config)
   - zed
   - vscode (if templated)

:: fzf reads colors from ~/.config/fzf/opts on every launch — no reload needed.
   If a shell still has a stale $FZF_DEFAULT_OPTS from before the
   FZF_DEFAULT_OPTS_FILE switchover, run: unset FZF_DEFAULT_OPTS
:: open a new shell for sesh / gum to pick up other env-var theme vars
   (or run: source ~/.zshrc)
EOF
