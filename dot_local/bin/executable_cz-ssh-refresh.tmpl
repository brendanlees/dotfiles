#!/usr/bin/env bash
set -euo pipefail

FAIL_HARD=false
case "${1:-}" in
  --fail)
    FAIL_HARD=true
    shift
    ;;
  -h|--help)
    echo "Usage: cz-ssh-refresh [--fail]"
    exit 0
    ;;
  "")
    ;;
  *)
    echo "Usage: cz-ssh-refresh [--fail]" >&2
    exit 2
    ;;
esac

warn() { echo "warn: $*" >&2; }

die_or_skip() {
  if [[ "$FAIL_HARD" == true ]]; then
    echo "error: $*" >&2
    exit 1
  fi
  warn "$*"
  exit 0
}

require_command() {
  local name=$1
  if ! command -v "$name" >/dev/null 2>&1; then
    die_or_skip "$name is required for SSH Bitwarden refresh"
  fi
}

role_has() {
  local scope=$1
  [[ ",${CHEZMOI_ROLE:-}," == *",$scope,"* ]]
}

template_bool_enabled() {
  local value=$1
  [[ "$value" == "true" ]]
}

template_personal='{{ if .personal }}true{{ else }}false{{ end }}'
template_work='{{ if .work }}true{{ else }}false{{ end }}'
template_homelab='{{ if .homelab }}true{{ else }}false{{ end }}'
template_ephemeral='{{ if .ephemeral }}true{{ else }}false{{ end }}'
# {{ $template_manifest_item := "" }}
# {{ if and (hasKey . "ssh") (hasKey .ssh "bw_manifest_item") }}{{ $template_manifest_item = (.ssh.bw_manifest_item | replace "'" "'\\''") }}{{ end }}
# {{ $template_agent_sock_env := "BITWARDEN_SSH_AUTH_SOCK" }}
# {{ if and (hasKey . "ssh") (hasKey .ssh "bw_agent_sock_env") }}{{ $template_agent_sock_env = (.ssh.bw_agent_sock_env | replace "'" "'\\''") }}{{ end }}
# shellcheck disable=SC2016
template_manifest_item='{{ $template_manifest_item }}'
# shellcheck disable=SC2016
template_agent_sock_env='{{ $template_agent_sock_env }}'

scope_enabled() {
  local scope=$1
  case "$scope" in
    personal)
      role_has personal || template_bool_enabled "$template_personal"
      ;;
    work)
      role_has work || template_bool_enabled "$template_work"
      ;;
    homelab)
      role_has homelab || template_bool_enabled "$template_homelab"
      ;;
    *)
      return 1
      ;;
  esac
}

expand_home_path() {
  local path=$1
  case "$path" in
    \~)
      printf '%s\n' "$HOME"
      ;;
    \~/*)
      printf '%s/%s\n' "$HOME" "${path#\~/}"
      ;;
    "$HOME"/*)
      printf '%s\n' "$path"
      ;;
    *)
      return 1
      ;;
  esac
}

canonical_dir() {
  local dir=$1
  (cd "$dir" 2>/dev/null && pwd -P)
}

path_has_symlink_component() {
  local base=$1
  local target=$2
  local rel=${target#"$base"/}
  local current=$base
  local component

  IFS='/' read -r -a components <<< "$rel"
  for component in "${components[@]}"; do
    [[ -n "$component" ]] || continue
    current="$current/$component"
    if [[ -L "$current" ]]; then
      return 0
    fi
  done
  return 1
}

ensure_private_path() {
  local target_var=$1
  local path=$2
  local expanded key_parent ssh_real parent_real
  if ! expanded=$(expand_home_path "$path"); then
    die_or_skip "unsupported SSH key path '$path'; use a path under ~/.ssh"
  fi
  case "$expanded" in
    "$HOME/.ssh"/*)
      ;;
    *)
      die_or_skip "refusing to write SSH key outside ~/.ssh: $path"
      ;;
  esac
  case "${expanded#"$HOME/.ssh"/}" in
    "" | /* | *//* | . | ./* | */. | */./* | .. | ../* | */.. | */../*)
      die_or_skip "unsupported SSH key path '$path'; use a normalized path under ~/.ssh"
      ;;
  esac
  if [[ -L "$HOME/.ssh" ]]; then
    die_or_skip "refusing to write SSH key through symlinked ~/.ssh: $path"
  fi
  if path_has_symlink_component "$HOME/.ssh" "$expanded"; then
    die_or_skip "refusing to write SSH key through symlinked path component: $path"
  fi
  key_parent=$(dirname "$expanded")
  if ! mkdir -p "$key_parent"; then
    die_or_skip "unable to create SSH key parent for '$path'"
  fi
  if path_has_symlink_component "$HOME/.ssh" "$expanded"; then
    die_or_skip "refusing to write SSH key through symlinked path component: $path"
  fi
  if ! ssh_real=$(canonical_dir "$HOME/.ssh"); then
    die_or_skip "unable to resolve ~/.ssh for SSH key path '$path'"
  fi
  if ! parent_real=$(canonical_dir "$key_parent"); then
    die_or_skip "unable to resolve SSH key parent for '$path'"
  fi
  case "$parent_real/" in
    "$ssh_real"/*)
      ;;
    *)
      die_or_skip "refusing to write SSH key outside canonical ~/.ssh: $path"
      ;;
  esac
  if [[ -L "$expanded" ]]; then
    die_or_skip "refusing to write SSH key through symlinked key path: $path"
  fi
  printf -v "$target_var" '%s' "$expanded"
}

read_host_required() {
  local target_var=$1
  local host_alias=$2
  local field=$3
  local value
  if ! value=$(jq -er --arg host "$host_alias" --arg field "$field" '.hosts[$host][$field] // empty' <<< "$manifest_json"); then
    die_or_skip "host '$host_alias' requires field '$field'"
  fi
  printf -v "$target_var" '%s' "$value"
}

validate_agent_sock_env() {
  local name=$1
  if [[ ! "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    die_or_skip "invalid SSH agent socket environment variable name '$name'"
  fi
}

safe_hint_name() {
  local name=$1
  case "$name" in
    *[!A-Za-z0-9._-]* | "")
      die_or_skip "invalid SSH key name '$name'"
      ;;
  esac
  printf '%s\n' "$name"
}

append_option_lines() {
  local config_file=$1
  local host_alias=$2
  local option_lines=$3
  local name value
  while IFS=$'\t' read -r name value; do
    [[ -n "$name" ]] || continue
    printf '  %s %s\n' "$name" "$value" >> "$config_file"
  done <<< "$option_lines"
}

if role_has ephemeral || template_bool_enabled "$template_ephemeral"; then
  exit 0
fi

manifest_item="${SSH_BW_MANIFEST_ITEM:-$template_manifest_item}"
case "$manifest_item" in
  *"{"*"{"*) manifest_item="" ;;
esac
if [[ -z "$manifest_item" ]]; then
  die_or_skip "SSH Bitwarden manifest item is not configured"
fi

agent_sock_env="${SSH_BW_AGENT_SOCK_ENV:-$template_agent_sock_env}"
case "$agent_sock_env" in
  "" | *"{"*"{"*) agent_sock_env="BITWARDEN_SSH_AUTH_SOCK" ;;
esac
validate_agent_sock_env "$agent_sock_env"
agent_sock_value="${!agent_sock_env:-\$$agent_sock_env}"

require_command bw
require_command jq

ssh_dir="$HOME/.ssh"
config_dir="$ssh_dir/config.d"
keys_dir="$ssh_dir/keys"
public_keys_dir="$ssh_dir/public-keys"
mkdir -p "$config_dir" "$keys_dir" "$public_keys_dir"
chmod 700 "$ssh_dir" "$config_dir" "$keys_dir" "$public_keys_dir" 2>/dev/null || true

tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/cz-ssh-refresh.XXXXXX")
cleanup() { rm -rf "$tmpdir"; }
trap cleanup EXIT

for scope in personal work homelab; do
  if scope_enabled "$scope"; then
    : > "$tmpdir/$scope.conf"
  fi
done

if ! manifest_item_json=$(bw get item "$manifest_item" 2>/dev/null); then
  die_or_skip "unable to read SSH Bitwarden manifest item '$manifest_item'"
fi

if ! manifest_json=$(jq -er '.notes | fromjson' <<< "$manifest_item_json" 2>/dev/null); then
  die_or_skip "SSH Bitwarden manifest item notes must contain manifest JSON"
fi

if ! jq -e '(.keys | type == "object") and (.hosts | type == "object")' <<< "$manifest_json" >/dev/null; then
  die_or_skip "SSH Bitwarden manifest must contain object keys and hosts"
fi

while IFS= read -r host_alias; do
  [[ -n "$host_alias" ]] || continue
  host_scope=""
  host_name=""
  key_name=""
  case "$host_alias" in
    *[$'\n\r\t ']* | "")
      die_or_skip "invalid SSH host alias '$host_alias'"
      ;;
  esac

  read_host_required host_scope "$host_alias" scope
  if ! scope_enabled "$host_scope"; then
    continue
  fi

  read_host_required host_name "$host_alias" host
  user_name=$(jq -r --arg host "$host_alias" '.hosts[$host].user // empty' <<< "$manifest_json")
  port=$(jq -r --arg host "$host_alias" '.hosts[$host].port // empty' <<< "$manifest_json")
  key_name=$(jq -r --arg host "$host_alias" '.hosts[$host].key // empty' <<< "$manifest_json")

  config_file="$tmpdir/$host_scope.conf"
  printf 'Host %s\n' "$host_alias" >> "$config_file"
  printf '  HostName %s\n' "$host_name" >> "$config_file"
  if [[ -n "$user_name" ]]; then
    printf '  User %s\n' "$user_name" >> "$config_file"
  fi
  if [[ -n "$port" ]]; then
    printf '  Port %s\n' "$port" >> "$config_file"
  fi

  if [[ -z "$key_name" ]]; then
    options=$(jq -r --arg host "$host_alias" '.hosts[$host].options // {} | to_entries[] | [.key, (.value | tostring)] | @tsv' <<< "$manifest_json")
    append_option_lines "$config_file" "$host_alias" "$options"
    printf '\n' >> "$config_file"
    continue
  fi

  key_mode=$(jq -r --arg key "$key_name" '.keys[$key].mode // empty' <<< "$manifest_json")
  key_scope=$(jq -r --arg key "$key_name" '.keys[$key].scope // empty' <<< "$manifest_json")
  key_public=$(jq -r --arg key "$key_name" '.keys[$key].public_key // empty' <<< "$manifest_json")
  key_path=$(jq -r --arg key "$key_name" '.keys[$key].path // empty' <<< "$manifest_json")
  key_item=$(jq -r --arg key "$key_name" '.keys[$key].item // empty' <<< "$manifest_json")

  if [[ -z "$key_mode" ]]; then
    die_or_skip "host '$host_alias' references missing key '$key_name'"
  fi
  if [[ -n "$key_scope" && "$key_scope" != "$host_scope" ]]; then
    die_or_skip "host '$host_alias' scope does not match key '$key_name' scope"
  fi

  case "$key_mode" in
    local_file)
      if [[ -z "$key_item" || -z "$key_path" ]]; then
        die_or_skip "local_file key '$key_name' requires item and path"
      fi
      expanded_key_path=""
      ensure_private_path expanded_key_path "$key_path"
      key_parent=$(dirname "$expanded_key_path")
      chmod 700 "$key_parent" 2>/dev/null || true
      if ! key_item_json=$(bw get item "$key_item" 2>/dev/null); then
        die_or_skip "unable to read SSH key item '$key_item'"
      fi
      if ! private_key=$(jq -er '.sshKey.privateKey // empty' <<< "$key_item_json"); then
        die_or_skip "SSH key item '$key_item' has no private key"
      fi
      item_public=$(jq -er '.sshKey.publicKey // empty' <<< "$key_item_json" 2>/dev/null || true)
      if [[ -z "$key_public" ]]; then
        key_public=$item_public
      fi
      umask 077
      printf '%s\n' "$private_key" > "$expanded_key_path"
      chmod 600 "$expanded_key_path"
      if [[ -n "$key_public" ]]; then
        expanded_public_key_path="$expanded_key_path.pub"
        if [[ -L "$expanded_public_key_path" ]]; then
          die_or_skip "refusing to write SSH public key through symlinked key path: $key_path.pub"
        fi
        printf '%s\n' "$key_public" > "$expanded_public_key_path"
        chmod 644 "$expanded_public_key_path"
      fi
      printf '  IdentityFile %s\n' "$key_path" >> "$config_file"
      ;;
    bitwarden_agent)
      safe_name=$(safe_hint_name "$key_name")
      if [[ -z "$key_public" ]]; then
        die_or_skip "bitwarden_agent key '$key_name' requires public_key"
      fi
      public_path=""
      ensure_private_path public_path "$HOME/.ssh/public-keys/$safe_name.pub"
      printf '%s\n' "$key_public" > "$public_path"
      chmod 644 "$public_path"
      if [[ -n "$key_path" ]]; then
        if stale_path=$(expand_home_path "$key_path") && [[ -e "$stale_path" ]]; then
          warn "local private key still exists for bitwarden_agent key '$key_name': $key_path"
        fi
      fi
      printf '  IdentityAgent %s\n' "$agent_sock_value" >> "$config_file"
      printf '  IdentityFile ~/.ssh/public-keys/%s.pub\n' "$safe_name" >> "$config_file"
      ;;
    *)
      die_or_skip "unsupported SSH key mode '$key_mode' for key '$key_name'"
      ;;
  esac

  options=$(jq -r --arg host "$host_alias" '.hosts[$host].options // {} | to_entries[] | [.key, (.value | tostring)] | @tsv' <<< "$manifest_json")
  append_option_lines "$config_file" "$host_alias" "$options"
  printf '\n' >> "$config_file"
done < <(jq -r '.hosts | keys[]' <<< "$manifest_json")

for scope in personal work homelab; do
  if [[ -f "$tmpdir/$scope.conf" ]]; then
    mv "$tmpdir/$scope.conf" "$config_dir/$scope.conf"
    chmod 600 "$config_dir/$scope.conf"
  fi
done
