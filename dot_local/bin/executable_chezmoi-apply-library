#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: chezmoi-apply-library [--dry-run] [--verbose]

Re-apply all tracked files under Library/ from the current chezmoi source state.
Shows pending Library drift before applying, and reports whether drift remains after.
USAGE
}

dry_run=false
verbose=false

library_target_path() {
  local source_path="$1"
  local dir base
  dir="$(dirname "$source_path")"
  base="$(basename "$source_path")"

  case "$base" in
    private_*) base="${base#private_}" ;;
  esac
  case "$base" in
    symlink_*) base="${base#symlink_}" ;;
  esac
  case "$base" in
    executable_*) base="${base#executable_}" ;;
  esac
  case "$base" in
    *.tmpl) base="${base%.tmpl}" ;;
  esac

  if [[ "$dir" == "." ]]; then
    printf '%s/%s\n' "$HOME" "$base"
  else
    printf '%s/%s/%s\n' "$HOME" "$dir" "$base"
  fi
}

library_status() {
  chezmoi status "${targets[@]}" 2>/dev/null || true
}

library_diff() {
  chezmoi diff "${targets[@]}" 2>/dev/null || true
}

while (($#)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -n|--dry-run)
      dry_run=true
      ;;
    -v|--verbose)
      verbose=true
      ;;
    *)
      echo "error: unsupported argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

source_root="$(chezmoi source-path)"
if [[ -z "$source_root" ]]; then
  echo "error: could not determine chezmoi source directory" >&2
  exit 1
fi

targets=()
while IFS= read -r source_path; do
  [[ "$source_path" == Library/* ]] || continue
  target_path="$(library_target_path "$source_path")"
  targets+=("$target_path")
done < <(git -C "$source_root" ls-files -- 'Library/**')

if ((${#targets[@]} == 0)); then
  echo "No tracked Library files found."
  exit 0
fi

printf 'Tracked Library files: %d\n' "${#targets[@]}"

pending="$(library_status)"
if [[ -z "$pending" ]]; then
  echo "No Library drift detected before apply."
  exit 0
fi

printf 'Pending Library changes before apply:\n%s\n' "$pending"
if $verbose; then
  diff_output="$(library_diff)"
  if [[ -n "$diff_output" ]]; then
    printf '\nPending Library diff:\n%s\n' "$diff_output"
  fi
fi

cmd=(chezmoi apply --force)
$dry_run && cmd+=(--dry-run)
$verbose && cmd+=(--verbose)
cmd+=("${targets[@]}")

"${cmd[@]}"

if $dry_run; then
  echo "Dry run complete; no files changed."
  exit 0
fi

remaining="$(library_status)"
if [[ -z "$remaining" ]]; then
  echo "Library files clean after apply."
else
  printf 'Remaining Library drift after apply:\n%s\n' "$remaining"
fi
