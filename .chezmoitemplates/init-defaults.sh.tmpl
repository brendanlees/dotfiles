#!/bin/bash
set -euo pipefail

# ------------------------------------------
# set defaults
# ------------------------------------------

# --- set zsh to default shell ---

if ! command -v zsh &>/dev/null; then
    echo "zsh not found, skipping shell change"
elif [ ! -f ~/.zshrc ]; then
    echo "Set zsh as default shell"
    chsh -s "$(which zsh)"
else
    echo "zsh already default shell, skipping."
fi