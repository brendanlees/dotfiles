{{- $p := (index .themes .theme).palette }}
# GlazeWM config (active theme: {{ .theme }})
# Mirrors macOS AeroSpace config; theme accents from .chezmoidata/themes.yml.

# ------------------------------------------
# defaults
# ------------------------------------------

general:
  startup_commands:
    - 'shell-exec zebar'
    - 'shell-exec tacky-borders'
  shutdown_commands:
    - 'shell-exec taskkill /IM zebar.exe /F'
    - 'shell-exec taskkill /IM tacky-borders.exe /F'
  config_reload_commands: []

  focus_follows_cursor: false
  toggle_workspace_on_refocus: true  # alt-tab back-and-forth feel

  cursor_jump:
    enabled: true
    trigger: 'monitor_focus'  # mirrors AeroSpace on-focused-monitor-changed

  hide_method: 'cloak'
  show_all_in_taskbar: false

# ------------------------------------------
# layout control
# ------------------------------------------

gaps:
  scale_with_dpi: true
  inner_gap: '10px'
  outer_gap:
    top: '50px'
    right: '10px'
    bottom: '10px'
    left: '10px'

window_effects:
  # tacky-borders draws borders; disable GlazeWM's own
  focused_window:
    border:
      enabled: false
    hide_title_bar:
      enabled: false
    corner_style:
      enabled: false
      style: 'square'
    transparency:
      enabled: false
  other_windows:
    border:
      enabled: false
    hide_title_bar:
      enabled: false
    corner_style:
      enabled: false
      style: 'square'
    transparency:
      enabled: false

window_behavior:
  initial_state: 'tiling'
  state_defaults:
    floating:
      centered: true
      shown_on_top: false
    fullscreen:
      maximized: false
      shown_on_top: false

# ------------------------------------------
# workspaces
# ------------------------------------------

workspaces:
  - name: '1-browser'
    display_name: '1'
  - name: '2-code'
    display_name: '2'
  - name: '3-email'
    display_name: '3'
  - name: '4-files'
    display_name: '4'
  - name: '5-docs'
    display_name: '5'
  - name: '6-misc1'
    display_name: '6'
  - name: '7-misc2'
    display_name: '7'
  - name: '8-notes'
    display_name: '8'
  - name: '9-music'
    display_name: '9'

# ------------------------------------------
# window detection
# ------------------------------------------

window_rules:
  - commands: ['ignore']
    match:
      # Ignore Zebar and tacky-borders themselves.
      - window_process: { equals: 'zebar' }
      - window_process: { equals: 'tacky-borders' }

      # Picture-in-picture browsers.
      - window_title: { regex: '[Pp]icture.in.[Pp]icture' }
        window_class: { regex: 'Chrome_WidgetWin_1|MozillaDialogClass' }

      # PowerToys helpers.
      - window_process: { equals: 'PowerToys' }
        window_class: { regex: 'HwndWrapper\[PowerToys\.PowerAccent.*?\]' }
      - window_title: { equals: 'Command Palette' }
        window_class: { equals: 'WinUIDesktopWin32WindowClass' }
      - window_process: { equals: 'PowerToys' }
        window_title: { regex: '.*? - Peek' }

      # MS Office dialogs (only manage main window).
      - window_process: { equals: 'EXCEL' }
        window_class: { not_regex: 'XLMAIN' }
      - window_process: { equals: 'WINWORD' }
        window_class: { not_regex: 'OpusApp' }
      - window_process: { equals: 'POWERPNT' }
        window_class: { not_regex: 'PPTFrameClass' }

  # --- 1. browser ---
  - commands: ['move --workspace 1-browser']
    match:
      - window_process: { equals: 'zen' }

  # --- 2. code ---
  - commands: ['move --workspace 2-code']
    match:
      - window_process: { equals: 'Code' }

  # --- 3. email / work ---
  - commands: ['move --workspace 3-email']
    match:
      - window_process: { equals: 'Notion' }

  # --- 5. docs ---
  - commands: ['move --workspace 5-docs']
    match:
      - window_process: { equals: 'Figma' }
      - window_process: { equals: 'WINWORD' }

  # --- 6. misc1 ---
  - commands: ['move --workspace 6-misc1']
    match:
      - window_process: { equals: 'Discord' }

  # --- 8. notes ---
  - commands: ['move --workspace 8-notes']
    match:
      - window_process: { equals: 'Obsidian' }
      - window_process: { equals: 'Todoist' }

  # --- 9. music ---
  - commands: ['move --workspace 9-music']
    match:
      - window_process: { equals: 'Spotify' }

# ------------------------------------------
# binding modes
# ------------------------------------------

binding_modes:
  # 'service' mode equivalent (alt+shift+;).
  # Simplified: GlazeWM has no flatten-workspace-tree or join-with-{dir}.
  - name: 'service'
    keybindings:
      - commands: ['wm-reload-config', 'wm-disable-binding-mode --name service']
        bindings: ['escape']
      - commands: ['wm-reload-config', 'wm-disable-binding-mode --name service']
        bindings: ['r']
      - commands: ['toggle-floating --centered', 'wm-disable-binding-mode --name service']
        bindings: ['f']
      - commands: ['close', 'wm-disable-binding-mode --name service']
        bindings: ['backspace']

  # Arrow / HJKL resize mode (GlazeWM default).
  - name: 'resize'
    keybindings:
      - commands: ['resize --width -2%']
        bindings: ['h', 'left']
      - commands: ['resize --width +2%']
        bindings: ['l', 'right']
      - commands: ['resize --height +2%']
        bindings: ['k', 'up']
      - commands: ['resize --height -2%']
        bindings: ['j', 'down']
      - commands: ['wm-disable-binding-mode --name resize']
        bindings: ['escape', 'enter']

# ------------------------------------------
# keybindings
# ------------------------------------------

keybindings:
  # --- focus ---
  - commands: ['focus --direction left']
    bindings: ['alt+h']
  - commands: ['focus --direction down']
    bindings: ['alt+j']
  - commands: ['focus --direction up']
    bindings: ['alt+k']
  - commands: ['focus --direction right']
    bindings: ['alt+l']

  # --- move ---
  - commands: ['move --direction left']
    bindings: ['alt+shift+h']
  - commands: ['move --direction down']
    bindings: ['alt+shift+j']
  - commands: ['move --direction up']
    bindings: ['alt+shift+k']
  - commands: ['move --direction right']
    bindings: ['alt+shift+l']

  # --- resize ---
  - commands: ['resize --width -50px', 'resize --height -50px']
    bindings: ['alt+shift+minus']
  - commands: ['resize --width +50px', 'resize --height +50px']
    bindings: ['alt+shift+equal']
  - commands: ['wm-enable-binding-mode --name resize']
    bindings: ['alt+r']

  # --- layout ---
  - commands: ['toggle-tiling-direction']
    bindings: ['alt+slash']
  - commands: ['toggle-fullscreen']
    bindings: ['alt+f']
  - commands: ['toggle-floating --centered']
    bindings: ['alt+shift+space']
  - commands: ['toggle-tiling']
    bindings: ['alt+t']

  # --- window ---
  - commands: ['close']
    bindings: ['alt+shift+q']
  - commands: ['toggle-minimized']
    bindings: ['alt+m']

  # --- WM control ---
  - commands: ['wm-reload-config']
    bindings: ['alt+shift+r']
  - commands: ['wm-exit']
    bindings: ['alt+shift+e']
  - commands: ['wm-toggle-pause']
    bindings: ['alt+shift+p']

  # --- service mode (AeroSpace alt+shift+;) ---
  - commands: ['wm-enable-binding-mode --name service']
    bindings: ['alt+shift+semicolon']

  # --- workspace navigation ---
  - commands: ['focus --prev-active-workspace']
    bindings: ['ctrl+alt+left']
  - commands: ['focus --next-active-workspace']
    bindings: ['ctrl+alt+right']
  - commands: ['focus --recent-workspace']
    bindings: ['alt+tab']

  # --- focus workspace ---
  - commands: ['focus --workspace 1-browser']
    bindings: ['alt+1']
  - commands: ['focus --workspace 2-code']
    bindings: ['alt+2']
  - commands: ['focus --workspace 3-email']
    bindings: ['alt+3']
  - commands: ['focus --workspace 4-files']
    bindings: ['alt+4']
  - commands: ['focus --workspace 5-docs']
    bindings: ['alt+5']
  - commands: ['focus --workspace 6-misc1']
    bindings: ['alt+6']
  - commands: ['focus --workspace 7-misc2']
    bindings: ['alt+7']
  - commands: ['focus --workspace 8-notes']
    bindings: ['alt+8']
  - commands: ['focus --workspace 9-music']
    bindings: ['alt+9']

  # --- move window to workspace (and follow) ---
  - commands: ['move --workspace 1-browser', 'focus --workspace 1-browser']
    bindings: ['alt+shift+1']
  - commands: ['move --workspace 2-code', 'focus --workspace 2-code']
    bindings: ['alt+shift+2']
  - commands: ['move --workspace 3-email', 'focus --workspace 3-email']
    bindings: ['alt+shift+3']
  - commands: ['move --workspace 4-files', 'focus --workspace 4-files']
    bindings: ['alt+shift+4']
  - commands: ['move --workspace 5-docs', 'focus --workspace 5-docs']
    bindings: ['alt+shift+5']
  - commands: ['move --workspace 6-misc1', 'focus --workspace 6-misc1']
    bindings: ['alt+shift+6']
  - commands: ['move --workspace 7-misc2', 'focus --workspace 7-misc2']
    bindings: ['alt+shift+7']
  - commands: ['move --workspace 8-notes', 'focus --workspace 8-notes']
    bindings: ['alt+shift+8']
  - commands: ['move --workspace 9-music', 'focus --workspace 9-music']
    bindings: ['alt+shift+9']
