{{/* ─── feature flags ─── */}}
{{- $personal  := false -}}
{{- $work      := false -}}
{{- $homelab   := false -}}
{{- $ephemeral := false -}}
{{- $headless  := false -}}

{{/* ─── hostname ─── */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{/* ─── ephemeral detection ─── */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS") (env "GITPOD_WORKSPACE_ID") (env "CI") (eq .chezmoi.username "ubuntu" "vagrant" "vscode") -}}
{{-   $ephemeral = true -}}
{{- end -}}

{{/* ─── env var override ─── */}}
{{- $role := env "CHEZMOI_ROLE" -}}
{{- if $role -}}
{{-   if regexMatch "(^|,)personal(,|$)" $role }}{{ $personal = true }}{{ end -}}
{{-   if regexMatch "(^|,)work(,|$)"     $role }}{{ $work     = true }}{{ end -}}
{{-   if regexMatch "(^|,)homelab(,|$)"  $role }}{{ $homelab  = true }}{{ end -}}
{{-   if regexMatch "(^|,)headless(,|$)" $role }}{{ $headless = true }}{{ end -}}
{{- end -}}

{{/* ─── machine type ─── */}}
{{- if and (not $ephemeral) (not $role) -}}
{{-   if eq $hostname "bAir" -}}
{{-     $personal = true -}}
{{-     $work = true -}}
{{-   else if eq $hostname "" -}}{{/* work-only machines */}}
{{-     $work = true -}}
{{-   else if eq $hostname "pve1" "pve2" "truenas" "pihole" "rpi1" "traefik" "servarr" "duplicacy" -}}
{{-     $homelab = true -}}
{{-   else if stdinIsATTY -}}
{{-     $personal = promptBoolOnce . "personal" "Is this a personal and/or homelab admin machine (y/n)" -}}
{{-     if $personal -}}
{{-       $work = promptBoolOnce . "work" "Are you also using this machine for work (y/n)" -}}
{{-     else -}}
{{-       $work = promptBoolOnce . "work" "Is this a work machine (y/n)" -}}
{{-       if not $work -}}
{{-         $homelab = promptBoolOnce . "homelab" "Is this machine part of your homelab (y/n)" -}}
{{-       end -}}
{{-     end -}}
{{-     if not (or $personal $work $homelab) -}}
{{-       warnf "chezmoi: no machine type set — re-run 'chezmoi init' to reconfigure" -}}
{{-     end -}}
{{-   else if or .personal .work .homelab -}}
{{-     $personal = .personal -}}
{{-     $work = .work -}}
{{-     $homelab = .homelab -}}
{{-   else -}}
{{-     $ephemeral = true -}}
{{-   end -}}
{{- end -}}

{{/* ─── headless ─── */}}
{{- if $homelab -}}
{{-   $headless = true -}}
{{- else if and $work (not $personal) -}}{{/* personal machines assumed GUI */}}
{{-   if stdinIsATTY -}}
{{-     $headless = promptBoolOnce . "headless" "Is this a headless machine (no GUI) (y/n)" -}}
{{-   else if .headless -}}
{{-     $headless = .headless -}}
{{-   end -}}
{{- end -}}

{{/* ─── git identity ─── */}}
{{- $git_name  := "" -}}
{{- $git_email := "" -}}
{{- if and (not $personal) $work -}}
{{-   $git_name  = promptStringOnce . "git_name"  "Git full name" -}}
{{-   $git_email = promptStringOnce . "git_email" "Git email" -}}
{{- end -}}

[data]
  personal  = {{ $personal }}
  work      = {{ $work }}
  homelab   = {{ $homelab }}
  ephemeral = {{ $ephemeral }}
  headless  = {{ $headless }}
{{- if and (not $personal) $work }}
  git_name  = {{ $git_name | quote }}
  git_email = {{ $git_email | quote }}
{{- end }}
  nerd_font   = "JetBrainsMono"
  font_family = "JetBrainsMono Nerd Font Mono"
{{ if and $personal (lookPath "bw") }}
[bitwarden]
  unlock = "auto"
{{ end }}

