{{/* ─── feature flags ─── */}}
{{- $personal  := false -}}
{{- $work      := false -}}
{{- $homelab   := false -}}
{{- $ephemeral := false -}}

{{/* ─── hostname ─── */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{/* ─── ephemeral detection ─── */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS") (env "GITPOD_WORKSPACE_ID") (env "CI") (eq .chezmoi.username "ubuntu" "vagrant" "vscode") -}}
{{-   $ephemeral = true -}}
{{- end -}}

{{/* ─── machine type ─── */}}
{{- if not $ephemeral -}}
{{-   if eq $hostname "bAir" -}}
{{-     $personal = true -}}
{{-     $work = true -}}
{{-   else if eq $hostname "" -}}{{/* work-only machines */}}
{{-     $work = true -}}
{{-   else if eq $hostname "pve1" "pve2" "truenas" "pihole" "rpi1" "traefik" "servarr" "duplicacy" -}}
{{-     $homelab = true -}}
{{-   else if stdinIsATTY -}}
{{-     $personal = promptBoolOnce . "personal" "Is this a personal machine?" -}}
{{-     if $personal -}}
{{-       $work = promptBoolOnce . "work" "Is this machine also used for work?" -}}
{{-     else -}}
{{-       $work = promptBoolOnce . "work" "Is this a work machine?" -}}
{{-       if not $work -}}
{{-         $homelab = promptBoolOnce . "homelab" "Is this a homelab machine?" -}}
{{-       end -}}
{{-     end -}}
{{-     if not (or $personal $work $homelab) -}}
{{-       warnf "chezmoi: no machine type set — re-run 'chezmoi init' to reconfigure" -}}
{{-     end -}}
{{-   else if or .personal .work .homelab -}}
{{-     $personal = .personal -}}
{{-     $work = .work -}}
{{-     $homelab = .homelab -}}
{{-   else -}}
{{-     $ephemeral = true -}}
{{-   end -}}
{{- end -}}

{{/* ─── git identity ─── */}}
{{- $git_name  := "" -}}
{{- $git_email := "" -}}
{{- if or $personal $work -}}
{{-   $git_name  = promptStringOnce . "git_name"  "Git full name" -}}
{{-   $git_email = promptStringOnce . "git_email" "Git email" -}}
{{- end -}}

[data]
  personal  = {{ $personal }}
  work      = {{ $work }}
  homelab   = {{ $homelab }}
  ephemeral = {{ $ephemeral }}
{{- if or $personal $work }}
  git_name  = {{ $git_name | quote }}
  git_email = {{ $git_email | quote }}
{{- end }}
