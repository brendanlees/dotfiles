# theme
theme = TokyoNight Night
window-padding-x = 8
window-padding-y = 0
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = hidden
macos-window-shadow = false
bold-is-bright = true
background-blur = macos-glass-regular

# icons
#macos-icon = glass
#macos-icon = retro
#macos-icon-frame = plastic
#macos-icon-ghost-color = #ffffff

# type
window-inherit-font-size = false
font-family = {{ .font_family }}
window-title-font-family = {{ .font_family }}
font-size = 20
font-style = medium

# clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
cursor-click-to-move = true

# functionality
shell-integration-features = ssh-terminfo,sudo
confirm-close-surface = false
auto-update = download
mouse-hide-while-typing = true
cursor-click-to-move = true

# keybinds
keybind = cmd+shift+,=reload_config

# remotes
shell-integration = zsh
keybind = shift+enter=text:\x1b\r

# shaders
custom-shader-animation = true 
#custom-shader = ~/.config/ghostty/shaders/glitchy.glsl
custom-shader = ~/.config/ghostty/shaders/cursor_s
# custom-shader = ~/.config/ghostty/shaders/space.glsl

