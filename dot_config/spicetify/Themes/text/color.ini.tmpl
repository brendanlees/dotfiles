; Generated by chezmoi from .chezmoidata/themes.yml.
; The text theme expects these keys in each color scheme section:
; accent, accent-active, accent-inactive, banner, border-active,
; border-inactive, header, highlight, main, notification,
; notification-error, subtext, and text.
{{- range $name := keys .themes | sortAlpha }}
{{- $p := (index $.themes $name).palette }}

[{{ $name }}]
accent             = {{ trimPrefix "#" $p.accent | lower }}
accent-active      = {{ trimPrefix "#" $p.primary | lower }}
accent-inactive    = {{ trimPrefix "#" $p.surface | lower }}
banner             = {{ trimPrefix "#" $p.accent | lower }}
border-active      = {{ trimPrefix "#" $p.accent | lower }}
border-inactive    = {{ trimPrefix "#" $p.border | lower }}
header             = {{ trimPrefix "#" $p.comment | lower }}
highlight          = {{ trimPrefix "#" $p.surface_alt | lower }}
main               = {{ trimPrefix "#" $p.bg | lower }}
notification       = {{ trimPrefix "#" $p.success | lower }}
notification-error = {{ trimPrefix "#" $p.error | lower }}
subtext            = {{ trimPrefix "#" $p.muted | lower }}
text               = {{ trimPrefix "#" $p.fg | lower }}
{{- end }}
