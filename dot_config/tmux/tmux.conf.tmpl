# use zsh as default
set -g default-shell /bin/zsh

# enable 256-color and true-color (24-bit) support in tmux
set -g default-terminal "tmux-256color" # Set terminal type for 256-color support
set -as terminal-features ",*:RGB"

# general
set -g focus-events on          # Pass focus events to applications (e.g. Neovim autoread)
set -g display-time 3000        # Show tmux messages for 3 seconds (default: 750ms)
{{- if eq .chezmoi.os "darwin" }}
set -g set-clipboard on          # Local tmux handles OSC 52 and sets macOS clipboard
{{- else }}
set -g set-clipboard external    # Remote tmux passes OSC 52 through to outer terminal
{{- end }}
set -ag terminal-features '*:clipboard'  # Enable OSC 52 for SSH clipboard support
set -g detach-on-destroy off    # Don't exit from tmux when closing a session
set -g escape-time 0            # Remove delay for exiting insert mode with ESC in Neovim
set -g history-limit 1000000    # Increase history size (from 2,000)
set -g mouse on                 # Enable mouse support
set -g set-titles on             # Let Moshi/terminal see session and window names
set -g set-titles-string "#I: #W"
set -g status-interval 3        # Update the status bar every 3 seconds (default: 15 seconds)
set -g allow-passthrough on   # Allow programs in the pane to bypass tmux (e.g. for image preview)
set -s extended-keys on                  # Distinguish C-S-h from C-h (CSI u / xterm modifyOtherKeys)
set -s extended-keys-format csi-u        # Use modern CSI u encoding (preferred by Pi, Ghostty, kitty, etc.)
set -as terminal-features ",*:extkeys"   # Advertise extended-keys capability to all terminals

# borders
set -g pane-border-lines double
set -g pane-border-indicators both
set -g pane-active-border-style 'fg=magenta,bg=default'
set -g pane-border-style 'fg=brightblack,bg=default'

# reload config file
unbind r
bind r source-file ~/.config/tmux/tmux.conf

# don't rename windows automatically
set-option -g allow-rename off

# start index at 1
set -g base-index 1
set -g pane-base-index 1

# new window in same path
bind c new-window -c "#{pane_current_path}"

# renumber when window is closed
set -g renumber-windows on

# resize panes using vim motions (after prefix)
bind -r j resize-pane -D 5
bind -r k resize-pane -U 5
bind -r l resize-pane -R 5
bind -r h resize-pane -L 5

# move between windows with ctrl+shift+h/l
bind-key -n C-S-h previous-window
bind-key -n C-S-l next-window

# swap windows with ctrl+shift+alt+h/l
bind-key -n C-S-M-h swap-window -t -1 \; select-window -t -1
bind-key -n C-S-M-l swap-window -t +1 \; select-window -t +1

# skip "kill-*? (y/n)" prompts
bind-key x kill-pane 
bind-key & kill-window

# set status bar to top
set-option -g status-position top

set-window-option -g mode-keys vi

# vi-style copy mode bindings
bind-key -T copy-mode-vi 'v' send -X begin-selection # start selecting text with "v"

# sesh config / integration
bind-key "K" run-shell "~/.config/sesh/scripts/picker.sh --tmux"
# tmux-yank configuration (cross-platform clipboard)
# These settings must come BEFORE the plugin is loaded
set -g @yank_selection 'clipboard'          # Copy to system clipboard (not just tmux buffer)
set -g @yank_selection_mouse 'clipboard'    # Mouse selection also copies to system clipboard
set -g @yank_with_mouse 'on'                # Enable mouse copy

# Manual clipboard bindings (fallback if tmux-yank doesn't load)
# tmux-yank will override these when it loads
{{- if eq .chezmoi.os "darwin" }}
bind-key -T copy-mode-vi 'y' send -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel "pbcopy"
{{- else if eq .chezmoi.os "linux" }}
# Linux - try wl-copy (Wayland) or xclip (X11)
bind-key -T copy-mode-vi 'y' send -X copy-pipe-and-cancel "if command -v wl-copy >/dev/null 2>&1; then wl-copy; elif command -v xclip >/dev/null 2>&1; then xclip -selection clipboard; else xsel --clipboard --input; fi"
bind-key -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel "if command -v wl-copy >/dev/null 2>&1; then wl-copy; elif command -v xclip >/dev/null 2>&1; then xclip -selection clipboard; else xsel --clipboard --input; fi"
{{- end }}

# maximize/restore a pane
bind-key -n C-f resize-pane -Z

#  plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'wfxr/tmux-fzf-url'

# urls
set -g @fzf-url-fzf-options '-p 60%,30% --prompt="   " --border-label=" Open URL "'
set -g @fzf-url-history-limit '2000'

# save / restore sessions
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'

# reset style options left behind by previously-loaded theme plugins.
# `set -g` values persist in the running server across `source-file`, so without
# this an old plugin's window-style would survive a theme switch and tint pane
# bgs the wrong colour. ukiyo (and any pane/border styles set above) will
# re-apply immediately after.
set -gu window-style
set -gu window-active-style

# theme (driven by .chezmoidata/themes.yml — active: {{ .theme }})
# Single multi-theme plugin (Kanagawa, Tokyo Night, Rose Pine, Catppuccin, ...)
{{- $p := (index .themes .theme).palette }}
set -g @plugin 'Nybkox/tmux-ukiyo'
set -g @ukiyo-theme "{{ (index .themes .theme).apps.tmux_ukiyo }}"
set -g @ukiyo-ignore-window-colors true   # preserve ghostty's bg in panes
set -g @ukiyo-show-powerline false        # flat blocks (no separators / caps)
set -g @ukiyo-show-flags true
# left icon: skull (nf-md-skull) constant across states. On prefix-hold, ukiyo
# flips the segment bg to `alert` (warn/yellow); fg uses ukiyo's default
# (`bg_pane`, aliased to $p.bg) so the skull renders dark on yellow.
set -g @ukiyo-left-icon "󰚌 #S"
set -g @ukiyo-military-time true
set -g @ukiyo-refresh-rate 5
set -g @ukiyo-plugins ""                  # no right-side plugins

# semantic color overrides — pin ukiyo bar bg to the active theme's bg so the
# tmux status bar visually merges with the ghostty terminal bg.
set -g @ukiyo-color-bg-bar  "{{ $p.bg }}"
set -g @ukiyo-color-bg-pane "{{ $p.bg }}"
# subdued left-icon: repurpose `accent` (used as left_icon_bg) to our subtle
# surface tone, and alias ukiyo's `muted` slot to our palette's `comment` so
# the title fg matches inactive window names and fades into the bar.
# Prefix-on still uses `alert` (warn/yellow bg) so it stands out when toggled.
set -g @ukiyo-color-accent  "{{ $p.surface }}"
set -g @ukiyo-color-muted   "{{ $p.comment }}"
set -g @ukiyo-left-icon-fg  "muted"

# set plugin install path (XDG-compliant, overrides TPM default of ~/.tmux/plugins/)
set-environment -g TMUX_PLUGIN_MANAGER_PATH '~/.config/tmux/plugins/'

# run tmux plugin manager
run '~/.config/tmux/plugins/tpm/tpm'

# window-status overrides (must come AFTER tpm so they win over ukiyo's defaults).
# Goal: keep ukiyo's rounded outer caps on left-icon + right segments, but render
# the window list as flat "N: title" cells with no separator caps, and a muted
# fg for inactive windows.
set -g window-status-separator ""
# window title format. Inactive windows are padded with 2 spaces per side to
# match the outer width of the active window's `⣏ ... ⣹` brackets, so cell
# widths are constant and switching active never shifts the layout.
# The trailing #{?window_zoomed_flag,...} appends a zoom-expand glyph
# (󰊓 nf-md-arrow_expand_all) when the active pane in that window is
# maximized via prefix+z (or our C-f).
set -g window-status-format         "  #{?window_bell_flag,#[fg={{ $p.success }}],#[fg={{ $p.comment }}]}#I#[fg={{ $p.comment }}] #W#{?window_zoomed_flag, 󰊓,}  "
set -g window-status-current-format "#[fg={{ $p.border }}]⣏#[fg={{ $p.comment }}] #{?window_bell_flag,#[fg={{ $p.success }}],#[fg={{ $p.comment }}]}#I#[fg={{ $p.comment }}] #W#{?window_zoomed_flag, 󰊓,} #[fg={{ $p.border }}]⣹"
set -g window-status-style          "fg={{ $p.comment }},bg=default"
set -g window-status-current-style  "fg={{ $p.comment }},bg=default"

# Agent completion/bell notifications. Agent hooks/extensions emit BEL into
# tmux; tmux keeps the terminal bell private with visual-bell and marks only
# the window number with the active chezmoi theme's success color.
setw -g monitor-bell on
set -g bell-action any
set -g visual-bell on
set -g window-status-activity-style "fg={{ $p.warn }},bg=default"
set -g window-status-bell-style     "fg={{ $p.comment }},bg=default"

# right side intentionally empty
set -g status-right ""

# binding overrides
unbind -n C-a # Allow beginning of line shortcut
unbind -n C-e # Allow end of line shortcut
