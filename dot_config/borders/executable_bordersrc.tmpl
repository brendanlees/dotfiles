#!/bin/bash
{{- $p := (index .themes .theme).palette }}

# colors driven by .chezmoidata/themes.yml (active theme: {{ .theme }})
blue="0xff{{ trimPrefix "#" $p.primary | lower }}"
transparent="0x00000000"

options=(
  style=round
  width=6.0
  hidpi=on
  active_color="$blue"
  inactive_color="$transparent"
  blacklist="espanso,Todoist,SoundSource,Todoist Helper,TodoistWidgets,Tailscale,Sleeve,PastePal,Dropover,iPhone Mirroring"
)

borders "${options[@]}"
