[user]
{{- if and .personal (lookPath "bw") }}
  name  = {{ (bitwardenFields "item" "d256649b-8944-43a3-a016-abc1018ad825").name.value }}
  email = {{ (bitwardenFields "item" "d256649b-8944-43a3-a016-abc1018ad825").email.value }}
{{- else if and (not .personal) .work }}
  name  = {{ .git_name }}
  email = {{ .git_email }}
{{- else }}
  name  = {{ .chezmoi.username }}
  email = {{ .chezmoi.username }}@{{ .chezmoi.hostname }}
{{- end }}

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true
{{- if .personal }}

[includeIf "hasconfig:remote.*.url:*gitea.lab.brendans.cloud*"]
  path = ~/.config/git/gitea

[includeIf "hasconfig:remote.*.url:*github.com*"]
  path = ~/.config/git/github
{{- end }}
{{- if eq .chezmoi.os "darwin" }}

[credential]
  helper = osxkeychain
{{- end }}
