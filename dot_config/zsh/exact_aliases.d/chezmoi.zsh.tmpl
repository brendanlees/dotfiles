# ------------------------------------------
# .aliases/chezmoi
# ------------------------------------------

# apply
cza() { chezmoi apply --force --refresh-externals; }

# library helpers
_cz_lib_target_path() {
    local source_path="$1"
    local dir base
    dir="$(dirname "$source_path")"
    base="$(basename "$source_path")"

    case "$base" in
        private_*) base="${base#private_}" ;;
    esac
    case "$base" in
        symlink_*) base="${base#symlink_}" ;;
    esac
    case "$base" in
        executable_*) base="${base#executable_}" ;;
    esac
    case "$base" in
        *.tmpl) base="${base%.tmpl}" ;;
    esac

    if [ "$dir" = "." ]; then
        printf '%s/%s\n' "$HOME" "$base"
    else
        printf '%s/%s/%s\n' "$HOME" "$dir" "$base"
    fi
}

_cz_lib_targets() {
    local source_root source_path
    source_root="$(chezmoi source-path)" || return 1

    git -C "$source_root" ls-files -- 'Library/**' | while IFS= read -r source_path; do
        [[ "$source_path" == Library/* ]] || continue
        _cz_lib_target_path "$source_path"
    done
}

_cz_lib_run() {
    local mode="$1"
    shift

    local helper
    case "$mode" in
        apply) helper="$HOME/.local/bin/chezmoi-apply-library" ;;
        re-add) helper="$HOME/.local/bin/chezmoi-readd-library" ;;
        *)
            printf 'error: unsupported mode: %s\n' "$mode" >&2
            return 1
            ;;
    esac
    if [ -x "$helper" ]; then
        "$helper" "$@"
        return $?
    fi

    local dry_run=false verbose=false
    while (($#)); do
        case "$1" in
            -n|--dry-run) dry_run=true ;;
            -v|--verbose) verbose=true ;;
            --) shift; break ;;
            *)
                printf 'error: unsupported argument: %s\n' "$1" >&2
                return 1
                ;;
        esac
        shift
    done

    local targets=()
    while IFS= read -r target_path; do
        targets+=("$target_path")
    done < <(_cz_lib_targets)

    if ((${#targets[@]} == 0)); then
        printf 'No tracked Library files found.\n'
        return 0
    fi

    local cmd=(chezmoi "$mode" --force)
    $dry_run && cmd+=(--dry-run)
    $verbose && cmd+=(--verbose)
    cmd+=("${targets[@]}")

    "${cmd[@]}"
}

cz-lib-apply() { _cz_lib_run apply "$@"; }
cz-lib-readd() { _cz_lib_run re-add "$@"; }

# init with a single bw prompt (unlocks vault once, passes session via env)
cz-bw-init() {
    command -v bw >/dev/null || {
        printf 'cz-bw-init: bw not on PATH\n' >&2
        return 1
    }
    local s
    s="$(bw unlock --raw)" || return 1
    BW_SESSION="$s" chezmoi init "$@"
}

# purge system & reinit
# refuses if there is unpushed work or extra worktrees in the chezmoi source dir
czr() {
    local src
    src="$(chezmoi source-path)" || return 1

    if [ -n "$(git -C "$src" status --porcelain)" ]; then
        printf 'czr: refusing — dirty working tree in %s\n' "$src" >&2
        git -C "$src" status --short >&2
        return 1
    fi

    local unpushed
    unpushed="$(git -C "$src" log --branches --not --remotes --oneline 2>/dev/null)"
    if [ -n "$unpushed" ]; then
        printf 'czr: refusing — local commits not on any remote in %s:\n' "$src" >&2
        printf '%s\n' "$unpushed" >&2
        return 1
    fi

    if [ "$(git -C "$src" worktree list | wc -l)" -gt 1 ]; then
        printf 'czr: refusing — extra worktrees exist:\n' >&2
        git -C "$src" worktree list >&2
        return 1
    fi

    printf 'czr: this will WIPE %s and reinit. type "yes" to proceed: ' "$src"
    local reply
    read -r reply
    if [ "$reply" != "yes" ]; then
        printf 'czr: aborted\n' >&2
        return 1
    fi

    chezmoi purge --force && chezmoi init --apply brendanlees
}
