# ------------------------------------------
# .aliases/headroom
# ------------------------------------------

_headroom_source_file="${(%):-%N}"
_headroom_source_dir="${_headroom_source_file:A:h}"
_headroom_repo_root="${_headroom_source_dir:h:h:h}"
_headroom_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"

if [ -f "$_headroom_repo_root/dot_config/headroom/env.zsh.tmpl" ] && [ -f "$_headroom_repo_root/dot_config/headroom/functions.zsh.tmpl" ]; then
    source "$_headroom_repo_root/dot_config/headroom/env.zsh.tmpl"
    source "$_headroom_repo_root/dot_config/headroom/functions.zsh.tmpl"
    if [ -d "$_headroom_repo_root/dot_local/bin" ]; then
        path=("$_headroom_repo_root/dot_local/bin" $path)
    fi
else
    source "$_headroom_config_home/headroom/env.zsh"
    source "$_headroom_config_home/headroom/functions.zsh"
fi

unset _headroom_source_file _headroom_source_dir _headroom_repo_root _headroom_config_home
