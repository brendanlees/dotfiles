# ------------------------------------------
# .aliases/headroom
# ------------------------------------------

# Privacy/safety defaults for Headroom. Keep these outside helper functions so
# child shells and manually-run `headroom` commands inherit them too.
export HEADROOM_TELEMETRY=off
export HEADROOM_TELEMETRY_WARN=off
export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
export HEADROOM_CODEX_SHIM_PORT="${HEADROOM_CODEX_SHIM_PORT:-8788}"
export HEADROOM_PROXY_WAIT_SECONDS="${HEADROOM_PROXY_WAIT_SECONDS:-15}"
export HEADROOM_STATS_INTERVAL="${HEADROOM_STATS_INTERVAL:-300}"
export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"

hr-env() {
    export HEADROOM_TELEMETRY=off
    export HEADROOM_TELEMETRY_WARN=off
    export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
    export HEADROOM_CODEX_SHIM_PORT="${HEADROOM_CODEX_SHIM_PORT:-8788}"
    export HEADROOM_PROXY_WAIT_SECONDS="${HEADROOM_PROXY_WAIT_SECONDS:-15}"
    export HEADROOM_STATS_INTERVAL="${HEADROOM_STATS_INTERVAL:-300}"
    export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"
    mkdir -p "$HEADROOM_WORKSPACE_DIR"
}

hr-proxy-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_PORT"
}

hr-proxy-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-proxy-url)/health" >/dev/null 2>&1
}

hr-codex-shim-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_CODEX_SHIM_PORT"
}

hr-codex-shim-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-codex-shim-url)/health" >/dev/null 2>&1
}

hr-wait-for-proxy() {
    hr-env
    local waited=0
    while ! hr-proxy-active; do
        if [ "$waited" -ge "$HEADROOM_PROXY_WAIT_SECONDS" ]; then
            printf 'Headroom proxy is not running on %s after %ss.
' "$(hr-proxy-url)" "$HEADROOM_PROXY_WAIT_SECONDS" >&2
            return 1
        fi
        if [ "$waited" -eq 0 ]; then
            printf 'Waiting for Headroom proxy on %s...
' "$(hr-proxy-url)" >&2
        fi
        sleep 1
        waited=$((waited + 1))
    done
    printf 'Headroom proxy active: %s
' "$(hr-proxy-url)"
}

hr-require-proxy() {
    hr-env
    if hr-proxy-active; then
        printf 'Headroom proxy active: %s\n' "$(hr-proxy-url)"
        return 0
    fi

    printf 'Headroom proxy is not running on %s.\n' "$(hr-proxy-url)" >&2
    printf 'Start it in another tmux pane/window with: hproxy\n' >&2
    return 1
}

hr-pi-provider-exists() {
    local provider="$1"
    pi --list-models "$provider" 2>/dev/null | awk 'NR > 1 { found = 1 } END { exit(found ? 0 : 1) }'
}

headroom-pi-codex-shim() {
    hr-env
    hr-wait-for-proxy || return $?

    printf 'Headroom Codex shim active while this command is running.
'
    printf 'URL: %s
' "$(hr-codex-shim-url)"
    printf 'Rewrite: /v1/codex/responses -> %s/v1/responses
' "$(hr-proxy-url)"
    printf 'Stop: Ctrl-C

'

    python3 - "$HEADROOM_CODEX_SHIM_PORT" "$(hr-proxy-url)" <<'PY'
import http.client
import http.server
import socketserver
import sys
from urllib.parse import urlparse

listen_port = int(sys.argv[1])
headroom = urlparse(sys.argv[2].rstrip('/'))
if headroom.scheme != 'http':
    raise SystemExit('headroom-pi-codex-shim currently supports http Headroom proxy URLs only')

class Handler(http.server.BaseHTTPRequestHandler):
    protocol_version = 'HTTP/1.1'

    def log_message(self, fmt, *args):
        sys.stderr.write('[headroom-pi-codex-shim] ' + fmt % args + '\n')

    def do_GET(self):
        if self.path == '/health':
            body = b'ok\n'
            self.send_response(200)
            self.send_header('content-type', 'text/plain')
            self.send_header('content-length', str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_error(404, 'not found')

    def do_POST(self):
        if self.path != '/v1/codex/responses':
            self.send_error(404, 'expected /v1/codex/responses')
            return

        length = int(self.headers.get('content-length') or 0)
        body = self.rfile.read(length)
        headers = {k: v for k, v in self.headers.items() if k.lower() not in {'host', 'content-length', 'connection'}}
        headers['content-length'] = str(len(body))

        conn = http.client.HTTPConnection(headroom.hostname, headroom.port or 80, timeout=None)
        try:
            conn.request('POST', '/v1/responses', body=body, headers=headers)
            upstream = conn.getresponse()
            self.send_response(upstream.status, upstream.reason)
            for key, value in upstream.getheaders():
                lower = key.lower()
                if lower in {'connection', 'keep-alive', 'proxy-authenticate', 'proxy-authorization', 'te', 'trailers', 'transfer-encoding', 'upgrade', 'content-length'}:
                    continue
                self.send_header(key, value)
            self.end_headers()
            while True:
                chunk = upstream.read(8192)
                if not chunk:
                    break
                self.wfile.write(chunk)
                self.wfile.flush()
        finally:
            conn.close()
            self.close_connection = True

class ThreadingHTTPServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True

ThreadingHTTPServer(('127.0.0.1', listen_port), Handler).serve_forever()
PY
}

headroom-watch-stats() {
    hr-env
    if command -v watch >/dev/null 2>&1; then
        watch -n "$HEADROOM_STATS_INTERVAL" hstats
        return $?
    fi

    while true; do
        clear
        hstats
        sleep "$HEADROOM_STATS_INTERVAL"
    done
}

hproxy-openrouter() {
    hproxy --openai-api-url https://openrouter.ai/api/v1 "$@"
}

hproxy-foreground() {
    hr-env

    printf 'Headroom proxy active while this command is running.
'
    printf 'URL: %s
' "$(hr-proxy-url)"
    printf 'Workspace: %s
' "$HEADROOM_WORKSPACE_DIR"
    printf 'Stop: Ctrl-C

'

    headroom proxy --port "$HEADROOM_PORT" --no-telemetry "$@"
}

hproxy() {
    hr-env

    if [ "${1:-}" = "--foreground" ]; then
        shift
        hproxy-foreground "$@"
        return $?
    fi

    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        local proxy_args="${(j: :)${(q)@}}"
        local proxy_cmd="source ~/.config/zsh/aliases.d/headroom.zsh; hproxy --foreground ${proxy_args}; exec zsh -l"
        local shim_cmd="source ~/.config/zsh/aliases.d/headroom.zsh; headroom-pi-codex-shim; exec zsh -l"
        local stats_cmd="source ~/.config/zsh/aliases.d/headroom.zsh; headroom-watch-stats; exec zsh -l"

        tmux new-window -n headroom "zsh -lc ${(q)proxy_cmd}"
        tmux select-pane -T proxy
        tmux split-window -h "zsh -lc ${(q)shim_cmd}"
        tmux select-pane -T codex-shim
        tmux split-window -v "zsh -lc ${(q)stats_cmd}"
        tmux select-pane -T stats
        tmux select-layout even-horizontal >/dev/null 2>&1 || true
        tmux select-pane -L >/dev/null 2>&1 || true
        return 0
    fi

    hproxy-foreground "$@"
}

hclaude() {
    hr-env
    hr-require-proxy || return $?
    headroom wrap claude --no-proxy -- "$@"
}

hcodex() {
    hr-env
    hr-require-proxy || return $?
    headroom wrap codex --no-proxy -- "$@"
}

hpi() {
    hr-env
    hr-require-proxy || return $?
    if ! hr-pi-provider-exists headroom-openrouter; then
        printf 'Pi provider "headroom-openrouter" is not configured yet.\n' >&2
        printf 'Add it to ~/.pi/agent/models.json before using hpi.\n' >&2
        return 1
    fi
    pi --model "${HEADROOM_PI_MODEL:-headroom-openrouter/openai/gpt-5.1-codex-mini}" "$@"
}

hpix() {
    hr-env
    hr-require-proxy || return $?
    if ! hr-pi-provider-exists headroom-codex-oauth; then
        printf 'Pi provider "headroom-codex-oauth" is not configured yet.
' >&2
        printf 'It also needs the local /v1/codex/responses -> /v1/responses shim.
' >&2
        return 1
    fi
    if ! hr-codex-shim-active; then
        printf 'Headroom Codex shim is not running on %s.
' "$(hr-codex-shim-url)" >&2
        printf 'Start it in another tmux pane/window with: headroom-pi-codex-shim
' >&2
        return 1
    fi
    pi --model "${HEADROOM_PIX_MODEL:-headroom-codex-oauth/gpt-5.4-mini}" "$@"
}

hstats() {
    hr-env
    headroom perf "$@"
}
