# ------------------------------------------
# .aliases/headroom
# ------------------------------------------

# Privacy/safety defaults for Headroom. Keep these outside helper functions so
# child shells and manually-run `headroom` commands inherit them too.
export HEADROOM_TELEMETRY=off
export HEADROOM_TELEMETRY_WARN=off
export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"

hr-env() {
    export HEADROOM_TELEMETRY=off
    export HEADROOM_TELEMETRY_WARN=off
    export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
    export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"
    mkdir -p "$HEADROOM_WORKSPACE_DIR"
}

hr-proxy-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_PORT"
}

hr-proxy-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-proxy-url)/health" >/dev/null 2>&1
}

hr-require-proxy() {
    hr-env
    if hr-proxy-active; then
        printf 'Headroom proxy active: %s\n' "$(hr-proxy-url)"
        return 0
    fi

    printf 'Headroom proxy is not running on %s.\n' "$(hr-proxy-url)" >&2
    printf 'Start it in another tmux pane/window with: hproxy\n' >&2
    return 1
}

hr-pi-provider-exists() {
    local provider="$1"
    pi --list-models "$provider" 2>/dev/null | awk 'NR > 1 { found = 1 } END { exit(found ? 0 : 1) }'
}

hproxy-openrouter() {
    hproxy --openai-api-url https://openrouter.ai/api/v1 "$@"
}

hproxy() {
    hr-env

    local old_tmux_name=""
    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        old_tmux_name="$(tmux display-message -p '#W' 2>/dev/null || true)"
        tmux rename-window "hproxy-on" 2>/dev/null || true
    fi

    printf 'Headroom proxy active while this command is running.\n'
    printf 'URL: %s\n' "$(hr-proxy-url)"
    printf 'Workspace: %s\n' "$HEADROOM_WORKSPACE_DIR"
    printf 'Stop: Ctrl-C\n\n'

    headroom proxy --port "$HEADROOM_PORT" --no-telemetry "$@"
    local status=$?

    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        tmux rename-window "hproxy-off" 2>/dev/null || true
        # Leave a visible hproxy-off reminder briefly, then restore prior name.
        if [ -n "$old_tmux_name" ]; then
            ( sleep 2; tmux rename-window "$old_tmux_name" 2>/dev/null || true ) >/dev/null 2>&1 &!
        fi
    fi

    return "$status"
}

hclaude() {
    hr-env
    hr-require-proxy || return $?
    headroom wrap claude --no-proxy -- "$@"
}

hcodex() {
    hr-env
    hr-require-proxy || return $?
    headroom wrap codex --no-proxy -- "$@"
}

hpi() {
    hr-env
    hr-require-proxy || return $?
    if ! hr-pi-provider-exists headroom-openrouter; then
        printf 'Pi provider "headroom-openrouter" is not configured yet.\n' >&2
        printf 'Add it to ~/.pi/agent/models.json before using hpi.\n' >&2
        return 1
    fi
    pi --model "${HEADROOM_PI_MODEL:-headroom-openrouter/openai/gpt-5.1-codex-mini}" "$@"
}

hpix() {
    hr-env
    hr-require-proxy || return $?
    if ! hr-pi-provider-exists headroom-codex-oauth; then
        printf 'Pi provider "headroom-codex-oauth" is not configured yet.\n' >&2
        printf 'It also needs the local /v1/codex/responses -> /v1/responses shim.\n' >&2
        return 1
    fi
    pi --model "${HEADROOM_PIX_MODEL:-headroom-codex-oauth/gpt-5.4-mini}" "$@"
}

hstats() {
    hr-env
    headroom perf "$@"
}
