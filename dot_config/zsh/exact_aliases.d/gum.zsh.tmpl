# ------------------------------------------
# .aliases/gum
# ------------------------------------------

# gum filter — preserve ANSI colors from input (e.g. sesh icons)
export GUM_FILTER_STRIP_ANSI=false

{{- $p := (index .themes .theme).palette }}
# gum filter — theme-driven via .chezmoidata/themes.yml
export GUM_FILTER_INDICATOR_FOREGROUND="{{ $p.secondary }}"          # selection dot
export GUM_FILTER_SELECTED_PREFIX_FOREGROUND="{{ $p.secondary }}"    # selected item prefix
export GUM_FILTER_UNSELECTED_PREFIX_FOREGROUND="{{ $p.border }}"     # unselected prefix
export GUM_FILTER_MATCH_FOREGROUND="{{ $p.primary }}"                # matched characters
export GUM_FILTER_PROMPT_FOREGROUND="{{ $p.accent }}"                # prompt (⚡)
export GUM_FILTER_CURSOR_TEXT_FOREGROUND="{{ $p.info }}"             # highlighted line text
export GUM_FILTER_TEXT_FOREGROUND="{{ $p.muted }}"                   # list text
export GUM_FILTER_PLACEHOLDER_FOREGROUND="{{ $p.border }}"           # placeholder
export GUM_FILTER_HEADER_FOREGROUND="{{ $p.accent }}"                # header (if used)
