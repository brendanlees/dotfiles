# ------------------------------------------
# zsh aliases
# ------------------------------------------

# define aliases directory
ALIASES_DIR="$XDG_CONFIG_HOME/zsh/aliases.d"

# source all alias files
if [ -d "$ALIASES_DIR" ]; then
    for alias_file in "$ALIASES_DIR"/*.zsh; do
        if [ -f "$alias_file" ]; then
            source "$alias_file"
        fi
    done
fi

