# Headroom environment defaults.

# read only token for improved hugging face access
#{{ if and .personal (lookPath "w") }}{{ printf "\nexport HF_TOKEN=%s" (.bw_huggingface.read_only_token | quote) }}{{ end }}

export HEADROOM_TELEMETRY=off
export HEADROOM_TELEMETRY_WARN=off
export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
export HEADROOM_CODEX_SHIM_PORT="${HEADROOM_CODEX_SHIM_PORT:-8788}"
export HEADROOM_CODEX_PROXY_PORT="${HEADROOM_CODEX_PROXY_PORT:-8789}"
export HEADROOM_CODEX_PROXY_OPTIMIZE="${HEADROOM_CODEX_PROXY_OPTIMIZE:-off}"
export HEADROOM_PROXY_WAIT_SECONDS="${HEADROOM_PROXY_WAIT_SECONDS:-15}"
export HEADROOM_STATS_INTERVAL="${HEADROOM_STATS_INTERVAL:-300}"
export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"
export HEADROOM_SAVINGS_PATH="${HEADROOM_SAVINGS_PATH:-$HEADROOM_WORKSPACE_DIR/proxy_savings.json}"


# Semantic pane text colors for the Headroom tmux dashboard.
_headroom_proxy_pane_color_default="#658594"
_headroom_stats_pane_color_default="#8a9a7b"
_headroom_shim_pane_color_default="#a292a3"
#{{ $p := (index .themes .theme).palette }}{{ printf "\n_headroom_proxy_pane_color_default=%q" $p.primary }}{{ printf "\n_headroom_stats_pane_color_default=%q" $p.success }}{{ printf "\n_headroom_shim_pane_color_default=%q" $p.secondary }}
export HEADROOM_PROXY_PANE_COLOR="${HEADROOM_PROXY_PANE_COLOR:-$_headroom_proxy_pane_color_default}"
export HEADROOM_STATS_PANE_COLOR="${HEADROOM_STATS_PANE_COLOR:-$_headroom_stats_pane_color_default}"
export HEADROOM_SHIM_PANE_COLOR="${HEADROOM_SHIM_PANE_COLOR:-$_headroom_shim_pane_color_default}"
unset _headroom_proxy_pane_color_default _headroom_stats_pane_color_default _headroom_shim_pane_color_default
