# Headroom reusable functions and public command wrappers.

hr-env() {
    #{{ if and .personal (lookPath "w") }}{{ printf "\n    export HF_TOKEN=%s" (.bw_huggingface.read_only_token | quote) }}{{ end }}
    export HEADROOM_TELEMETRY=off
    export HEADROOM_TELEMETRY_WARN=off
    export HEADROOM_PORT="${HEADROOM_PORT:-8787}"
    export HEADROOM_CODEX_SHIM_PORT="${HEADROOM_CODEX_SHIM_PORT:-8788}"
    export HEADROOM_CODEX_PROXY_PORT="${HEADROOM_CODEX_PROXY_PORT:-8789}"
    export HEADROOM_CODEX_PROXY_OPTIMIZE="${HEADROOM_CODEX_PROXY_OPTIMIZE:-off}"
    export HEADROOM_PROXY_WAIT_SECONDS="${HEADROOM_PROXY_WAIT_SECONDS:-15}"
    export HEADROOM_STATS_INTERVAL="${HEADROOM_STATS_INTERVAL:-300}"
    export HEADROOM_WORKSPACE_DIR="${HEADROOM_WORKSPACE_DIR:-$HOME/.headroom-private}"
    export HEADROOM_SAVINGS_PATH="${HEADROOM_SAVINGS_PATH:-$HEADROOM_WORKSPACE_DIR/proxy_savings.json}"
    mkdir -p "$HEADROOM_WORKSPACE_DIR"
}

hr-proxy-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_PORT"
}

hr-proxy-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-proxy-url)/health" >/dev/null 2>&1
}

hr-codex-shim-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_CODEX_SHIM_PORT"
}

hr-codex-proxy-url() {
    hr-env
    printf 'http://127.0.0.1:%s' "$HEADROOM_CODEX_PROXY_PORT"
}

hr-codex-proxy-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-codex-proxy-url)/health" >/dev/null 2>&1
}

hr-codex-shim-active() {
    hr-env
    command -v curl >/dev/null 2>&1 || return 127
    curl -fsS "$(hr-codex-shim-url)/health" >/dev/null 2>&1
}

hr-status() {
    hr-env
    printf 'Headroom status\n'
    printf '  proxy:      '
    if hr-proxy-active; then
        printf 'active at %s\n' "$(hr-proxy-url)"
    else
        printf 'not running at %s\n' "$(hr-proxy-url)"
    fi
    printf '  codex proxy:'
    if hr-codex-proxy-active; then
        printf ' active at %s\n' "$(hr-codex-proxy-url)"
    else
        printf ' not running at %s\n' "$(hr-codex-proxy-url)"
    fi
    printf '  codex shim: '
    if hr-codex-shim-active; then
        printf 'active at %s\n' "$(hr-codex-shim-url)"
    else
        printf 'not running at %s\n' "$(hr-codex-shim-url)"
    fi
    printf '  codex optimize: %s\n' "$HEADROOM_CODEX_PROXY_OPTIMIZE"
    printf '  workspace:  %s\n' "$HEADROOM_WORKSPACE_DIR"
    printf '  savings:    %s\n' "$HEADROOM_SAVINGS_PATH"

    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        printf '  tmux windows:\n'
        tmux list-windows -a -F '    #{session_name}:#{window_index}:#{window_name} panes=#{window_panes}' 2>/dev/null | grep ':headroom ' || printf '    none\n'
    fi
}

hr-wait-for-url() {
    local label="$1"
    local url="$2"
    local waited=0
    while ! curl -fsS "$url/health" >/dev/null 2>&1; do
        if [ "$waited" -ge "$HEADROOM_PROXY_WAIT_SECONDS" ]; then
            printf '%s is not running on %s after %ss.\n' "$label" "$url" "$HEADROOM_PROXY_WAIT_SECONDS" >&2
            return 1
        fi
        if [ "$waited" -eq 0 ]; then
            printf 'Waiting for %s on %s...\n' "$label" "$url" >&2
        fi
        sleep 1
        waited=$((waited + 1))
    done
    printf '%s active: %s\n' "$label" "$url"
}

hr-wait-for-proxy() {
    hr-env
    hr-wait-for-url 'Headroom proxy' "$(hr-proxy-url)"
}

hr-wait-for-codex-proxy() {
    hr-env
    hr-wait-for-url 'Headroom Codex proxy' "$(hr-codex-proxy-url)"
}

hr-require-proxy() {
    hr-env
    if hr-proxy-active; then
        printf 'Headroom proxy active: %s\n' "$(hr-proxy-url)"
        return 0
    fi

    printf 'Headroom proxy is not running on %s.\n' "$(hr-proxy-url)" >&2
    printf 'Start it with: hr-proxy-claude\n' >&2
    printf 'Diagnostics:\n' >&2
    hr-status >&2
    return 1
}

hr-pi-provider-exists() {
    local provider="$1"
    pi --list-models "$provider" 2>/dev/null | awk 'NR > 1 { found = 1 } END { exit(found ? 0 : 1) }'
}

hr-run-headroom-command() {
    local installed_name="$1"
    local repo_name="$2"
    shift 2

    if command -v "$repo_name" >/dev/null 2>&1; then
        command "$repo_name" "$@"
        return $?
    fi

    if command -v "$installed_name" >/dev/null 2>&1; then
        command "$installed_name" "$@"
        return $?
    fi

    command "$installed_name" "$@"
}

hr-codex-shim() {
    hr-env
    hr-wait-for-codex-proxy || return $?

    printf 'Headroom Codex shim active while this command is running.\n'
    printf 'URL: %s\n' "$(hr-codex-shim-url)"
    printf 'Rewrite: /v1/codex/responses -> %s/v1/responses\n' "$(hr-codex-proxy-url)"
    printf 'Stop: Ctrl-C\n\n'

    hr-run-headroom-command headroom-codex-shim executable_headroom-codex-shim "$HEADROOM_CODEX_SHIM_PORT" "$(hr-codex-proxy-url)"
}

hr-watch-stats() {
    hr-env
    if command -v watch >/dev/null 2>&1; then
        watch -n "$HEADROOM_STATS_INTERVAL" hr-stats
        return $?
    fi

    while true; do
        clear
        hr-stats
        sleep "$HEADROOM_STATS_INTERVAL"
    done
}

hr-proxy-pi() {
    hr-proxy-claude --openai-api-url https://openrouter.ai/api/v1 "$@"
}

hr-proxy-codex() {
    hr-env

    case "${1:-}" in
        -h|--help|help)
            headroom proxy --help
            return $?
            ;;
    esac

    printf 'Headroom Codex proxy active while this command is running.\n'
    printf 'URL: %s\n' "$(hr-codex-proxy-url)"
    printf 'Optimize: %s\n' "$HEADROOM_CODEX_PROXY_OPTIMIZE"
    printf 'Stop: Ctrl-C\n\n'

    if [ "$HEADROOM_CODEX_PROXY_OPTIMIZE" = "on" ]; then
        headroom proxy --port "$HEADROOM_CODEX_PROXY_PORT" --no-telemetry "$@"
        return $?
    fi

    headroom proxy --port "$HEADROOM_CODEX_PROXY_PORT" --no-telemetry --no-optimize "$@"
}

hr-proxy-claude-foreground() {
    hr-env

    case "${1:-}" in
        -h|--help|help)
            headroom proxy --help
            return $?
            ;;
    esac

    printf 'Headroom proxy active while this command is running.\n'
    printf 'URL: %s\n' "$(hr-proxy-url)"
    printf 'Workspace: %s\n' "$HEADROOM_WORKSPACE_DIR"
    printf 'Savings: %s\n' "$HEADROOM_SAVINGS_PATH"
    printf 'Stop: Ctrl-C\n\n'

    headroom proxy --port "$HEADROOM_PORT" --no-telemetry "$@"
}

hr-proxy-claude() {
    hr-env

    case "${1:-}" in
        -h|--help|help)
            hr-proxy-claude-foreground --help
            return $?
            ;;
    esac

    if [ "${1:-}" = "--foreground" ]; then
        shift
        hr-proxy-claude-foreground "$@"
        return $?
    fi

    if hr-proxy-active; then
        printf 'Headroom proxy already active: %s\n' "$(hr-proxy-url)"
        return 0
    fi

    if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
        hr-run-headroom-command headroom-tmux executable_headroom-tmux "$@"
        return $?
    fi

    hr-proxy-claude-foreground "$@"
}

hr-claude() {
    hr-env
    hr-require-proxy || return $?
    headroom wrap claude --no-proxy -- "$@"
}

hr-codex() {
    hr-env
    if ! hr-codex-proxy-active; then
        printf 'Headroom Codex proxy is not running on %s.\n' "$(hr-codex-proxy-url)" >&2
        printf 'Start it with: hr-proxy-pi (starts both OpenRouter and Codex proxies).\n' >&2
        return 1
    fi
    headroom wrap codex --no-proxy --port "$HEADROOM_CODEX_PROXY_PORT" -- "$@"
}

hr-pi() {
    hr-env
    hr-require-proxy || return $?
    if ! hr-pi-provider-exists headroom-openrouter; then
        printf 'Pi provider "headroom-openrouter" is not configured yet.\n' >&2
        printf 'Add it to ~/.pi/agent/models.json before using hr-pi.\n' >&2
        return 1
    fi
    pi --model "${HEADROOM_PI_MODEL:-headroom-openrouter/openai/gpt-5.1-codex-mini}" "$@"
}

hr-pix() {
    hr-env
    if ! hr-codex-proxy-active; then
        printf 'Headroom Codex proxy is not running on %s.\n' "$(hr-codex-proxy-url)" >&2
        printf 'Start it with: hr-proxy-pi (starts both OpenRouter and Codex proxies).\n' >&2
        return 1
    fi
    if ! hr-pi-provider-exists headroom-codex-oauth; then
        printf 'Pi provider "headroom-codex-oauth" is not configured yet.\n' >&2
        printf 'It also needs the local /v1/codex/responses -> /v1/responses shim.\n' >&2
        return 1
    fi
    if ! hr-codex-shim-active; then
        printf 'Headroom Codex shim is not running on %s.\n' "$(hr-codex-shim-url)" >&2
        printf 'This Pi/Codex OAuth path is bespoke and requires the local shim.\n' >&2
        printf 'Start it with: hr-codex-shim\n' >&2
        return 1
    fi
    pi --model "${HEADROOM_PIX_MODEL:-headroom-codex-oauth/gpt-5.4-mini}" --models "${HEADROOM_PIX_MODELS:-headroom-codex-oauth/gpt-5.4-mini,headroom-codex-oauth/gpt-5.5}" "$@"
}

hr-stats() {
    hr-env
    headroom perf "$@"
}

