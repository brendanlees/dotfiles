# fzf default options (theme-driven via .chezmoidata/themes.yml)
#
# Loaded by fzf at invocation time (FZF_DEFAULT_OPTS_FILE), so theme switches
# take effect on the next fzf launch — no shell reload required.
{{ $p := (index .themes .theme).palette -}}
--highlight-line
--info=inline-right
--ansi
--layout=reverse
--border=sharp
--color=fg:{{ $p.fg }},bg:{{ $p.bg }},hl:{{ $p.accent }},fg+:{{ $p.fg }},bg+:{{ $p.surface }},hl+:{{ $p.accent }}
--color=info:{{ $p.muted }},prompt:{{ $p.primary_alt }},pointer:{{ $p.accent }},marker:{{ $p.success }},spinner:{{ $p.accent }}
--color=header:{{ $p.primary_alt }},border:{{ $p.border }},separator:{{ $p.border }}
