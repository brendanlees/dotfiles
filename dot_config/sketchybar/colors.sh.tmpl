#!/bin/bash
{{ $p := (index .themes .theme).palette }}
# Sketchybar color palette
# Active theme: {{ .theme }}
# Format: 0xAARRGGBB

export BLACK=0xff{{ trimPrefix "#" $p.bg | lower }}
export WHITE=0xff{{ trimPrefix "#" $p.fg | lower }}
export RED=0xff{{ trimPrefix "#" $p.error | lower }}
export GREEN=0xff{{ trimPrefix "#" $p.success | lower }}
export BLUE=0xff{{ trimPrefix "#" $p.primary | lower }}
export YELLOW=0xff{{ trimPrefix "#" $p.warn | lower }}
export ORANGE=0xff{{ trimPrefix "#" $p.orange | lower }}
export MAGENTA=0xff{{ trimPrefix "#" $p.secondary | lower }}
export CYAN=0xff{{ trimPrefix "#" $p.info | lower }}
export ACCENT=0xff{{ trimPrefix "#" $p.accent | lower }}
export GREY=0xff{{ trimPrefix "#" $p.border | lower }}
export MUTED=0xff{{ trimPrefix "#" $p.muted | lower }}
export SURFACE=0xff{{ trimPrefix "#" $p.surface | lower }}
export TRANSPARENT=0x00000000

# bar (transparent so only the pills are visible)
export BAR_COLOR=$TRANSPARENT
export BAR_BORDER_COLOR=$TRANSPARENT
export ICON_COLOR=$WHITE
export LABEL_COLOR=$WHITE
export POPUP_BACKGROUND_COLOR=0xcc{{ trimPrefix "#" $p.bg | lower }}
export POPUP_BORDER_COLOR=0xff{{ trimPrefix "#" $p.surface | lower }}

# section accent colors (semantic palette keys, theme-driven)
export SPACES_COLOR=$BLUE        # primary
export FRONT_APP_COLOR=$MAGENTA  # secondary
export CALENDAR_COLOR=$CYAN      # info
export SPOTIFY_COLOR=$ACCENT     # accent

# pill background (translucent surface)
export PILL_BG=0x88{{ trimPrefix "#" $p.surface | lower }}

# active-space highlight block (translucent lighter surface)
export SPACE_ACTIVE_BG=0xaa{{ trimPrefix "#" $p.surface_alt | lower }}
