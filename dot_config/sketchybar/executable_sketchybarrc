#!/bin/bash

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

ITEM_DIR="$CONFIG_DIR/items"
export PLUGIN_DIR="$CONFIG_DIR/plugins"

FONT="JetBrainsMono Nerd Font Mono"
BAR_HEIGHT=38
PILL_HEIGHT=32
ITEM_PADDING=8
BAR_EDGE_PADDING=4
GROUP_GAP=6
MEDIA_GAP=0
BORDER_RADIUS=8

# ------------------------------------------
# bar appearance
# ------------------------------------------

sketchybar --bar \
  height="$BAR_HEIGHT" \
  color="$BAR_COLOR" \
  border_color="$BAR_BORDER_COLOR" \
  shadow=off \
  position=top \
  topmost=window \
  sticky=on \
  padding_right="$BAR_EDGE_PADDING" \
  padding_left="$BAR_EDGE_PADDING" \
  corner_radius="$BORDER_RADIUS" \
  y_offset=6 \
  margin=8 \
  blur_radius=20 \
  notch_width=0

# ------------------------------------------
# global defaults
# ------------------------------------------

sketchybar --default \
  icon.font="$FONT:Bold:14.0" \
  icon.color="$ICON_COLOR" \
  icon.padding_left="$ITEM_PADDING" \
  icon.padding_right="$ITEM_PADDING" \
  label.font="$FONT:Regular:13.0" \
  label.color="$LABEL_COLOR" \
  label.padding_left="$ITEM_PADDING" \
  label.padding_right="$ITEM_PADDING" \
  padding_left="$ITEM_PADDING" \
  padding_right="$ITEM_PADDING" \
  background.height="$PILL_HEIGHT" \
  background.corner_radius="$BORDER_RADIUS" \
  background.color="$PILL_BG" \
  background.border_width=1 \
  background.drawing=on \
  popup.background.border_width=1 \
  popup.background.corner_radius="$BORDER_RADIUS" \
  popup.background.border_color="$POPUP_BORDER_COLOR" \
  popup.background.color="$POPUP_BACKGROUND_COLOR" \
  popup.blur_radius=20 \
  popup.background.shadow.drawing=on # background.padding_left=3 \
# background.padding_right=3 \

# ------------------------------------------
# layout helpers
# ------------------------------------------

add_spacer() {
  local name="$1"
  local side="$2"
  local gap="${3:-$GROUP_GAP}"
  local drawing="${4:-on}"

  sketchybar --add item "spacer.$name" "$side" \
    --set "spacer.$name" \
    drawing="$drawing" \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    width="$gap" \
    padding_left=0 \
    padding_right=0
}

# ------------------------------------------
# events
# ------------------------------------------

sketchybar --add event aerospace_workspace_change

# ------------------------------------------
# left items (spaces)
# ------------------------------------------

source "$ITEM_DIR/spaces.sh"

# ------------------------------------------
# center items (focused app)
# ------------------------------------------

source "$ITEM_DIR/front_app.sh"

# ------------------------------------------
# right items
# ------------------------------------------

source "$ITEM_DIR/calendar.sh"
add_spacer calendar_status right
source "$ITEM_DIR/battery.sh"
add_spacer backup_sync right "$GROUP_GAP" off
source "$ITEM_DIR/backup_status.sh"
add_spacer status_sync right "$GROUP_GAP" off
# source "$ITEM_DIR/sync_status.sh"
source "$ITEM_DIR/tailscale.sh"
add_spacer status_spotify right "$MEDIA_GAP"
# source "$ITEM_DIR/app_soundsource.sh" # shelved for now
source "$ITEM_DIR/spotify.sh"

# ------------------------------------------
# finalise
# ------------------------------------------

sketchybar --hotload on
sketchybar --update
