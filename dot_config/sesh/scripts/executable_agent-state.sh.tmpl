#!/usr/bin/env bash
set -euo pipefail

state_dir() {
  if [[ -n "${AGENT_TMUX_STATE_DIR:-}" ]]; then
    printf '%s\n' "$AGENT_TMUX_STATE_DIR"
  elif [[ -n "${XDG_STATE_HOME:-}" ]]; then
    printf '%s/agent-tmux\n' "$XDG_STATE_HOME"
  else
    printf '%s/.local/state/agent-tmux\n' "$HOME"
  fi
}

quote_value() {
  local value=${1:-}
  printf "'%s'" "${value//\'/\'\\\'\'}"
}

record_path_for_pane() {
  local pane=${1:?pane required}
  printf '%s/pane-%s.env\n' "$(state_dir)" "$pane"
}

write_assignment() {
  local key=${1:?key required}
  local value=${2:-}
  printf '%s=%s\n' "$key" "$(quote_value "$value")"
}

load_record() {
  local file=${1:?file required}
  [[ -f "$file" ]] || return 1
  if grep -Evq "^[A-Z_][A-Z0-9_]*=" "$file"; then
    return 1
  fi
  # shellcheck disable=SC1090
  source "$file"
}

pane_exists() {
  local pane=${1:?pane required}
  command -v tmux >/dev/null 2>&1 || return 1
  tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -Fxq "$pane"
}

live_pane_metadata() {
  local pane=${1:?pane required}
  local format
  format=$'#{pane_id}\t#{session_id}\t#{session_name}\t#{window_id}\t#{window_index}\t#{window_name}\t#{pane_current_path}\t#{pane_current_command}\t#{pane_pid}'
  tmux list-panes -a -F "$format" 2>/dev/null | awk -F '\t' -v pane="$pane" '$1 == pane { print; found = 1; exit } END { exit found ? 0 : 1 }'
}

effective_harness() {
  local recorded=${1:-agent}
  local command=${2:-}
  case "$command" in
    pi)
      printf 'pi\n'
      ;;
    claude|claude-code)
      printf 'claude\n'
      ;;
    *)
      printf '%s\n' "$recorded"
      ;;
  esac
}

ansi_fg() {
  printf '\033[38;5;%sm' "$1"
}

ansi_reset() {
  printf '\033[0m'
}

ansi_underline() {
  printf '\033[4m'
}

ansi_no_underline() {
  printf '\033[24m'
}

color_harness() {
  case "${1:-agent}" in
    pi) ansi_fg 75 ;;
    claude) ansi_fg 208 ;;
    *) ansi_fg 141 ;;
  esac
}

color_state() {
  case "${1:-done}" in
    done) ansi_fg 114 ;;
    running) ansi_fg 221 ;;
    error) ansi_fg 203 ;;
    stale) ansi_fg 244 ;;
    *) ansi_fg 245 ;;
  esac
}

color_context() {
  ansi_fg 245
}

strip_ansi() {
  sed -E $'s/\x1B\[[0-9;]*[[:alpha:]]//g'
}

format_agent_row() {
  local harness=${1:?harness required}
  local state=${2:?state required}
  local session_name=${3:?session required}
  local window_index=${4:?window index required}
  local window_name=${5:?window name required}
  printf '%b%s%b  %b%s%b  %b%b%s%b:%s%b  %s\n' \
    "$(color_harness "$harness")" "$harness" "$(ansi_reset)" \
    "$(color_state "$state")" "$state" "$(ansi_reset)" \
    "$(color_context)" "$(ansi_underline)" "$session_name" "$(ansi_no_underline)" "$window_index" "$(ansi_reset)" \
    "$window_name"
}

write_done() {
  local harness=agent
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --harness)
        harness=${2:?--harness requires value}
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done

  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  command -v tmux >/dev/null 2>&1 || exit 0

  local line format
  format=$'#{pane_id}	#{session_id}	#{session_name}	#{window_id}	#{window_index}	#{window_name}	#{pane_current_path}'
  line=$(tmux display-message -p -t "$TMUX_PANE" "$format" 2>/dev/null || true)
  [[ -n "$line" ]] || exit 0

  local pane_id session_id session_name window_id window_index window_name pane_current_path
  IFS=$'\t' read -r pane_id session_id session_name window_id window_index window_name pane_current_path <<< "$line"
  [[ -n "$pane_id" ]] || exit 0

  local dir file tmp
  dir=$(state_dir)
  mkdir -p "$dir"
  file=$(record_path_for_pane "$pane_id")
  tmp="$file.$$"

  {
    write_assignment HARNESS "$harness"
    write_assignment STATE "done"
    write_assignment PANE_ID "$pane_id"
    write_assignment SESSION_ID "$session_id"
    write_assignment SESSION_NAME "$session_name"
    write_assignment WINDOW_ID "$window_id"
    write_assignment WINDOW_INDEX "$window_index"
    write_assignment WINDOW_NAME "$window_name"
    write_assignment PANE_CURRENT_PATH "$pane_current_path"
    write_assignment UPDATED_AT "$(date +%s)"
  } > "$tmp"
  mv "$tmp" "$file"
}

record_files() {
  local dir
  dir=$(state_dir)
  [[ -d "$dir" ]] || return 0
  find "$dir" -maxdepth 1 -type f -name 'pane-*.env' -print
}

valid_records() {
  local file live
  while IFS= read -r file; do
    unset HARNESS STATE PANE_ID SESSION_ID SESSION_NAME WINDOW_ID WINDOW_INDEX WINDOW_NAME PANE_CURRENT_PATH PANE_CURRENT_COMMAND PANE_PID UPDATED_AT
    if load_record "$file" && [[ "${STATE:-}" == "done" ]] && [[ -n "${PANE_ID:-}" ]] && live=$(live_pane_metadata "$PANE_ID"); then
      local live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid
      IFS=$'\t' read -r live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid <<< "$live"
      local display_harness
      display_harness=$(effective_harness "${HARNESS:-agent}" "${live_command:-${PANE_CURRENT_COMMAND:-}}")
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${UPDATED_AT:-0}" "${live_pane:-$PANE_ID}" "$display_harness" "${live_session_id:-${SESSION_ID:-}}" "${live_session_name:-${SESSION_NAME:-}}" \
        "${live_window_id:-${WINDOW_ID:-}}" "${live_window_index:-${WINDOW_INDEX:-}}" "${live_window_name:-${WINDOW_NAME:-}}" "${live_path:-${PANE_CURRENT_PATH:-}}" \
        "${live_command:-${PANE_CURRENT_COMMAND:-}}" "${live_pid:-${PANE_PID:-}}"
    else
      rm -f "$file" 2>/dev/null || true
    fi
  done < <(record_files)
}
list_records() {
  valid_records | sort -n | while IFS=$'\t' read -r _updated _pane harness _session_id session_name _window_id window_index window_name _path _command _pid; do
    format_agent_row "$harness" "done" "$session_name" "$window_index" "$window_name"
  done
}

pane_from_selection() {
  local selection=${1:-}
  if [[ "$selection" == agent:%* || "$selection" == %* ]]; then
    selection=${selection#agent:}
    printf '%s\n' "${selection%%[[:space:]]*}"
    return 0
  fi

  local plain harness state session_window session_name window_index window_name
  plain=$(printf '%s' "$selection" | strip_ansi)
  read -r harness state session_window window_name <<< "$plain"
  [[ -n "$harness" && -n "$state" && -n "$session_window" && -n "$window_name" ]] || return 1
  session_name=${session_window%:*}
  window_index=${session_window##*:}

  valid_records | sort -n | awk -F '\t' \
    -v harness="$harness" -v session="$session_name" -v win_index="$window_index" -v window="$window_name" \
    '$3 == harness && $5 == session && $7 == win_index && $8 == window { print $2; found = 1; exit } END { exit found ? 0 : 1 }'
}

preview_selection() {
  local selection=${*:-}
  local pane file
  if pane=$(pane_from_selection "$selection" 2>/dev/null); then
    file=$(record_path_for_pane "$pane")
    if load_record "$file" && live=$(live_pane_metadata "$pane"); then
      local live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid
      IFS=$'\t' read -r live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid <<< "$live"
      printf 'agent: %s\n' "$(effective_harness "${HARNESS:-agent}" "$live_command")"
      printf 'state: %s\n' "${STATE:-unknown}"
      printf 'pane: %s\n' "${live_pane:-$pane}"
      printf 'session: %s\n' "${live_session_name:-${SESSION_NAME:-unknown}}"
      printf 'window: %s:%s %s\n' "${live_window_index:-${WINDOW_INDEX:-?}}" "${live_window_id:-${WINDOW_ID:-?}}" "${live_window_name:-${WINDOW_NAME:-unknown}}"
      printf 'path: %s\n' "${live_path:-${PANE_CURRENT_PATH:-unknown}}"
      printf 'command: %s\n' "${live_command:-unknown}"
      printf 'updated: %s\n' "${UPDATED_AT:-unknown}"
      printf '\n'
    fi
    return 0
  fi

  local stripped session_name
  stripped=$(printf '%s' "$selection" | strip_ansi)
  session_name=${stripped##* }
  valid_records | sort -n | awk -F '\t' -v session="$session_name" '$5 == session {print; found=1; exit} END {exit found ? 0 : 1}' | while IFS=$'\t' read -r updated pane harness _session_id session window_id window_index window_name path command _pid; do
    printf 'agent: %s\nstate: done\npane: %s\nsession: %s\nwindow: %s:%s %s\npath: %s\ncommand: %s\nupdated: %s\n\n' \
      "$harness" "$pane" "$session" "$window_index" "$window_id" "$window_name" "$path" "${command:-unknown}" "$updated"
  done || true
}

jump_to_pane() {
  local pane=${1:?pane required}
  local file live live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid
  file=$(record_path_for_pane "$pane")
  load_record "$file" || return 1
  live=$(live_pane_metadata "${PANE_ID:-$pane}") || return 1
  IFS=$'\t' read -r live_pane live_session_id live_session_name live_window_id live_window_index live_window_name live_path live_command live_pid <<< "$live"
  tmux switch-client -t "${live_session_id:-${SESSION_ID:-${SESSION_NAME:-}}}" >/dev/null 2>&1 || true
  tmux select-window -t "${live_window_id:-${WINDOW_ID:-}}" >/dev/null 2>&1 || true
  tmux select-pane -t "${live_pane:-${PANE_ID:-$pane}}" >/dev/null 2>&1 || true
}

jump_oldest() {
  local row pane
  row=$(valid_records | sort -n | head -n 1 || true)
  if [[ -z "$row" ]]; then
    tmux display-message 'No actionable agent panes' 2>/dev/null || true
    return 0
  fi
  IFS=$'\t' read -r _updated pane _rest <<< "$row"
  jump_to_pane "$pane"
}

case "${1:-}" in
  write-done)
    shift
    write_done "$@"
    ;;
  list)
    list_records
    ;;
  preview)
    shift
    preview_selection "$@"
    ;;
  jump)
    jump_oldest
    ;;
  target)
    shift
    jump_to_pane "$(pane_from_selection "${*:-}")"
    ;;
  *)
    printf 'usage: %s {write-done|list|preview|jump|target}\n' "$0" >&2
    exit 2
    ;;
esac
