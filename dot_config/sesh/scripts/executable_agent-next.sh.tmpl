#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
agent_state=${AGENT_TMUX_STATE_SCRIPT:-$script_dir/agent-state.sh}

case "${1:-}" in
  --target)
    shift
    exec "$agent_state" target "$@"
    ;;
  *)
    exec "$agent_state" jump
    ;;
esac
