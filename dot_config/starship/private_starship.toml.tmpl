# ~/.config/starship/starship.toml

add_newline = false
command_timeout = 200
scan_timeout = 10

# Left prompt: only the character. Default `$all` silently runs ~50 module
# detection checks (battery, package, every language/cloud module) and adds
# ~50–80ms per render — none of which produces visible output here.
format = """$character"""
right_format = """$os$username$hostname$directory$git_branch$git_status${env_var.DDEV_PROJECT}"""

# STARSHIP_CACHE ramdisk: skipped on macOS (no tmpfs by default). Revisit on
# Linux hosts where `/dev/shm` or a tmpfs mount is available.


# palette driven by .chezmoidata/themes.yml
palette = '{{ (index .themes .theme).apps.starship }}'

[palettes.monokai]
# overrides
red = '#e87d3e'
green = '#b4d273'
yellow = '#e5b567'
blue = '#6c99bb'
black = '#2e2e2e'
white = '#d6d6d6'
gray = '#797979'

# semantic
accent = 'red'
primary = 'yellow'
neutral = 'gray'

[palettes.tokyo-night]
# overrides
red = '#f7768e'
green = '#9ece6a'
blue = '#769ff0'
white = '#c0caf5'

# semantic
accent = '#73daca'
primary = '#769ff0'
neutral = '#a9b1d6'

[palettes.kanagawa-wave]
# overrides
red = '#C34043'
green = '#98BB6C'
blue = '#7E9CD8'
white = '#DCD7BA'

# semantic
accent = '#7AA89F'
primary = '#7E9CD8'
neutral = '#C8C093'

[palettes.rosepine]
# overrides
red = '#eb6f92'
green = '#31748f'
blue = '#9ccfd8'
white = '#e0def4'

# semantic
accent = '#9ccfd8'
primary = '#31748f'
neutral = '#908caa'

[os]
format = '[$symbol](bold white) '
disabled = false

[os.symbols]
Windows = ''
Arch = '󰣇'
Ubuntu = ''
Macos = ''
Debian = '󰣚'

[character]
success_symbol = "[❯](accent)"
error_symbol = "[✗](red)"
vicmd_symbol = "[❮](red)"

# Shows the username
[username]
style_user = 'white bold'
style_root = 'red bold'
format = '[$user]($style) '
disabled = false
show_always = true

# Shows the hostname
[hostname]
ssh_only = false
format = '[on](neutral) [$hostname](primary bold) '
disabled = false

# Shows current directory
[directory]
style = 'accent bold'
truncation_length = 1
truncation_symbol = '…/'
home_symbol = ' ~'
read_only_style = '197'
read_only = '  '
format = '[at](neutral) [$path]($style)[$read_only]($read_only_style) '

# Shows current git branch
[git_branch]
symbol = ' '
format = 'via [$symbol$branch]($style)'
# truncation_length = 4
truncation_symbol = '…/'
style = 'bold green'

# Shows current git status
[git_status]
format = '([ \( $all_status$ahead_behind\)]($style) )'
style = 'bold green'
conflicted = '[ confliced=${count}](red) '
up_to_date = '[󰘽 up-to-date](green) '
untracked = '[󰋗 untracked=${count}](red) '
ahead = ' ahead=${count}'
diverged = ' ahead=${ahead_count}  behind=${behind_count}'
behind = ' behind=${count}'
stashed = '[ stashed=${count}](green) '
modified = '[󰛿 modified=${count}](yellow) '
staged = '[󰐗 staged=${count}](green) '
renamed = '[󱍸 renamed=${count}](yellow) '
deleted = '[󰍶 deleted=${count}](red) '

# ddev icon
[env_var.DDEV_PROJECT]
format = '[🐳 $env_value]($style) '
style = 'bold blue'
disabled = false

[bun]
disabled = true

[docker_context]
disabled = true

[container]
disabled = true

[lua]
disabled = true

[nodejs]
disabled = true

[php]
disabled = true

[python]
disabled = true
