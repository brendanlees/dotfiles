#!/bin/bash

# ------------------------------------------
# cleanup > remove old tool install locations
# (replaced by .chezmoiexternal.toml.tmpl and run_onchange scripts)
# ------------------------------------------

{{- if eq .chezmoi.os "linux" }}

# neovim — was extracted to /opt/nvim with symlink at /usr/local/bin/nvim
if [ -d "/opt/nvim" ]; then
  echo "removing old neovim bundle at /opt/nvim..."
  sudo rm -rf /opt/nvim
fi

if [ -L "/usr/local/bin/nvim" ]; then
  echo "removing old neovim symlink at /usr/local/bin/nvim..."
  sudo rm -f /usr/local/bin/nvim
fi

# lazygit — was installed to /usr/local/bin via sudo
if [ -f "/usr/local/bin/lazygit" ]; then
  echo "removing old lazygit at /usr/local/bin/lazygit..."
  sudo rm -f /usr/local/bin/lazygit
fi

{{- end }}
