# managed by chezmoi - keeps Pi pointed at the chezmoi-generated theme
# Windows-native port of run_onchange_after_configure-pi-settings.py (no Python needed)
$ErrorActionPreference = 'Stop'

$package = 'npm:@ogulcancelik/pi-ghostty-theme-sync'

if ($env:PI_AGENT_DIR) {
    $agentDir = $env:PI_AGENT_DIR
} else {
    $agentDir = Join-Path $HOME '.pi/agent'
}
$settingsPath = Join-Path $agentDir 'settings.json'

New-Item -ItemType Directory -Force -Path $agentDir | Out-Null

if (Test-Path -LiteralPath $settingsPath) {
    $data = Get-Content -Raw -LiteralPath $settingsPath | ConvertFrom-Json
    if ($data -isnot [pscustomobject]) {
        throw "$settingsPath must contain a JSON object"
    }
} else {
    $data = [pscustomobject]@{}
}

$data | Add-Member -NotePropertyName theme -NotePropertyValue 'chezmoi' -Force

$packages = @()
$packagesProp = $data.PSObject.Properties['packages']
if ($null -ne $packagesProp) {
    $value = $packagesProp.Value
    if ($value -is [string] -or $value -is [pscustomobject]) {
        throw "${settingsPath}: packages must be a list when present"
    }
    $packages = @($value)
}

# Mirror disable_ghostty_sync(): blank the theme-sync package's extensions.
$result = @()
foreach ($pkg in $packages) {
    if ($pkg -is [string] -and $pkg -eq $package) {
        $result += [pscustomobject]@{ source = $package; extensions = @() }
    }
    elseif ($pkg -is [pscustomobject] -and $pkg.source -eq $package) {
        $pkg | Add-Member -NotePropertyName extensions -NotePropertyValue @() -Force
        $result += $pkg
    }
    else {
        $result += $pkg
    }
}

$data | Add-Member -NotePropertyName packages -NotePropertyValue ([object[]]$result) -Force

# Write UTF-8 without BOM + trailing newline (matches the Python output; avoids
# Set-Content's BOM under Windows PowerShell 5.1, which breaks strict JSON parsers).
$json = $data | ConvertTo-Json -Depth 100
$utf8NoBom = New-Object System.Text.UTF8Encoding($false)
[System.IO.File]::WriteAllText($settingsPath, $json + "`n", $utf8NoBom)
Write-Output "configured Pi theme in $settingsPath"
