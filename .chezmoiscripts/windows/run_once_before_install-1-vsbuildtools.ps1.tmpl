# managed by chezmoi - install VS 2022 Build Tools (MSVC) for Rust + native deps
# Required by `rust` (scoop main bucket) which uses the MSVC toolchain by default —
# vcredist2022 alone is only the runtime; this gives us link.exe, the Windows SDK,
# and the C++ compiler/headers/libs that mise-built tools need.
$ErrorActionPreference = 'Stop'

# Skip if any VS install already has the VC++ tools workload installed
$vsWhere = "${env:ProgramFiles(x86)}\Microsoft Visual Studio\Installer\vswhere.exe"
if (Test-Path $vsWhere) {
    $hasVC = & $vsWhere -products * `
        -requires Microsoft.VisualStudio.Component.VC.Tools.x86.x64 `
        -property installationPath 2>$null
    if ($hasVC) {
        Write-Host "MSVC VC++ tools already present at $hasVC, skipping."
        return
    }
}

Write-Host "installing VS 2022 Build Tools with VCTools workload (multi-GB, will take a while)..."
winget install -e --id Microsoft.VisualStudio.2022.BuildTools `
    --accept-source-agreements --accept-package-agreements --silent `
    --override "--quiet --wait --add Microsoft.VisualStudio.Workload.VCTools --includeRecommended"
