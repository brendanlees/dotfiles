{{ if and (eq .chezmoi.os "darwin" "linux") (not .headless) (lookPath "code") -}}

{{- $extensions := fromJson (includeTemplate ".chezmoitemplates/merge-by-role.tmpl" (list .vscode .)) -}}

#!/bin/bash

set -euo pipefail

installed="$(code --list-extensions 2>/dev/null || true)"

{{ range $extensions -}}
if ! grep -Fxq '{{ . }}' <<<"$installed"; then
  code --force --install-extension {{ . }}
fi
{{ end -}}

{{ end -}}
