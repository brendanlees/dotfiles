{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

confirm_remote_script() {
  local name="$1"
  local url="$2"

  if [[ "${CHEZMOI_ALLOW_REMOTE_SCRIPTS:-}" == "1" ]]; then
    echo "CHEZMOI_ALLOW_REMOTE_SCRIPTS=1 set; allowing $name installer."
    return 0
  fi

  cat <<EOF
About to run remote installer: $name

Source:
  $url

Inspect before running:
  curl -fsSL "$url" | less

To skip this prompt in automation, rerun with:
  CHEZMOI_ALLOW_REMOTE_SCRIPTS=1

EOF

  if [[ ! -t 0 ]]; then
    echo "Refusing to run $name installer without confirmation in non-interactive mode." >&2
    return 1
  fi

  read -r -p "Continue running $name installer? [y/N] " answer
  case "$answer" in
    [Yy]|[Yy][Ee][Ss]) return 0 ;;
    *) echo "Skipped $name installer."; return 1 ;;
  esac
}

# ------------------------------------------
# install > mise (tool version manager)
# ------------------------------------------

if command -v mise &>/dev/null || [ -x "$HOME/.local/bin/mise" ]; then
  echo "mise already installed, skipping."
  exit 0
fi

mise_install_url="https://mise.run"
echo "installing mise..."
confirm_remote_script "mise" "$mise_install_url"
curl "$mise_install_url" | sh

echo "mise installed to ~/.local/bin/mise"
{{- end -}}
