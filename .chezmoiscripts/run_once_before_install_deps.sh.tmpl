#!/bin/bash

# ------------------------------------------
# linux
# ------------------------------------------

{{ if eq .chezmoi.os "linux" -}}

# --- root user --- #

{{ if eq .chezmoi.username "root" -}}

# install core dependencies if missing
missing=()
command -v zsh  &>/dev/null || missing+=(zsh)
command -v git  &>/dev/null || missing+=(git)
command -v ncdu &>/dev/null || missing+=(ncdu)

if [ ${#missing[@]} -gt 0 ]; then
	apt update && apt install -y "${missing[@]}"
fi

{{ end -}}

# --- all users --- #

{{ template "init-defaults.sh.tmpl" . }}
{{ end -}}

# ------------------------------------------
# mac os
# ------------------------------------------

{{ if eq .chezmoi.os "darwin" -}}

# install packages not available via mise on macOS
brew install btop ncdu
{{ if .personal -}}
brew install bitwarden-cli
{{ end -}}
{{ end -}}
