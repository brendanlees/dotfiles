{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

confirm_remote_script() {
  local name="$1"
  local url="$2"

  if [[ "${CHEZMOI_ALLOW_REMOTE_SCRIPTS:-}" == "1" ]]; then
    echo "CHEZMOI_ALLOW_REMOTE_SCRIPTS=1 set; allowing $name installer."
    return 0
  fi

  cat <<EOF
About to run remote installer: $name

Source:
  $url

Inspect before running:
  curl -fsSL "$url" | less

To skip this prompt in automation, rerun with:
  CHEZMOI_ALLOW_REMOTE_SCRIPTS=1

EOF

  if [[ ! -t 0 ]]; then
    echo "Refusing to run $name installer without confirmation in non-interactive mode." >&2
    return 1
  fi

  read -r -p "Continue running $name installer? [y/N] " answer
  case "$answer" in
    [Yy]|[Yy][Ee][Ss]) return 0 ;;
    *) echo "Skipped $name installer."; return 1 ;;
  esac
}

# ------------------------------------------
# linux
# ------------------------------------------

{{ if eq .chezmoi.os "linux" -}}

# --- root user --- #

{{ if eq .chezmoi.username "root" -}}

# install core dependencies if missing
missing=()
command -v zsh &>/dev/null || missing+=(zsh)
command -v git &>/dev/null || missing+=(git)
command -v unzip &>/dev/null || missing+=(unzip)

if command -v apk &>/dev/null; then
  # Alpine Linux
  if [ ${#missing[@]} -gt 0 ]; then
    apk add --no-cache "${missing[@]}"
  fi
  apk add --no-cache gcompat 2>/dev/null || true
elif command -v apt &>/dev/null; then
  # Debian/Ubuntu
  dpkg -s build-essential &>/dev/null 2>&1 || missing+=(build-essential)
  if [ ${#missing[@]} -gt 0 ]; then
    apt update && apt install -y "${missing[@]}"
  fi
fi

{{ else -}}

# non-root: try sudo
missing=()
command -v zsh &>/dev/null || missing+=(zsh)
command -v git &>/dev/null || missing+=(git)
command -v unzip &>/dev/null || missing+=(unzip)

if command -v apk &>/dev/null; then
  # Alpine Linux
  if [ ${#missing[@]} -gt 0 ]; then
    apk add --no-cache "${missing[@]}"
  fi
  apk add --no-cache gcompat 2>/dev/null || true
elif command -v apt &>/dev/null; then
  # Debian/Ubuntu
  dpkg -s build-essential &>/dev/null 2>&1 || missing+=(build-essential)
  if [ ${#missing[@]} -gt 0 ]; then
    if command -v sudo &>/dev/null; then
      sudo apt update && sudo apt install -y "${missing[@]}"
    else
      echo "WARNING: missing packages (${missing[*]}) and no sudo available"
    fi
  fi
fi

{{ end -}}

# --- all users --- #

{{ template "init-defaults.sh.tmpl" . }}
{{ end -}}

# ------------------------------------------
# mac os
# ------------------------------------------

{{ if eq .chezmoi.os "darwin" -}}

# check for declarative packages
homebrew_install_url="https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"
if ! command -v brew &>/dev/null; then
  confirm_remote_script "Homebrew" "$homebrew_install_url"
  /bin/bash -c "$(curl -fsSL "$homebrew_install_url")"
fi

{{ if or .personal .work -}}
# for secrets
brew install bitwarden-cli
{{ end -}}
{{ end -}}
{{- end -}}
