#!/bin/bash
set -euo pipefail

# ------------------------------------------
# security: lock down aliases directory
# ------------------------------------------

# restrict ~/.aliases to owner-only; prevents other processes from dropping
# files that would be auto-sourced on shell start
ALIASES_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/aliases.d"
if [ -d "$ALIASES_DIR" ]; then
  chmod 700 "$ALIASES_DIR"
fi

# ------------------------------------------
# resolve github token (rate-limit bypass)
# ------------------------------------------

# priority: env var > chezmoi data > age-encrypted file
if [ -z "${GITHUB_TOKEN:-}" ]; then
{{- if .github_token }}
  export GITHUB_TOKEN={{ .github_token | quote }}
{{- else }}
  _age_key="$HOME/.config/chezmoi/key.txt"
  _enc_token="{{ .chezmoi.sourceDir }}/.github_token.age"
  if [ -f "$_age_key" ] && [ -f "$_enc_token" ] && command -v age >/dev/null 2>&1; then
    GITHUB_TOKEN=$(age --decrypt -i "$_age_key" "$_enc_token" 2>/dev/null) || true
    [ -n "$GITHUB_TOKEN" ] && export GITHUB_TOKEN
  fi
{{- end }}
fi

# ------------------------------------------
# install > mise tools (runs on every chezmoi apply)
# ------------------------------------------

MISE="$HOME/.local/bin/mise"

if [ ! -x "$MISE" ]; then
  echo "mise not found at $MISE, skipping tool install."
  exit 1
fi

echo "installing mise tools..."
"$MISE" install

echo "mise tools installed."

# rebuild bat theme cache (bat may have just been installed)
if command -v bat &>/dev/null; then
  echo "Rebuilding bat theme cache..."
  bat cache --build
fi
