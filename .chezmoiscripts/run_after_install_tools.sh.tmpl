#!/bin/bash
set -euo pipefail

# ------------------------------------------
# install > mise tools (runs on every chezmoi apply)
# ------------------------------------------

MISE="$HOME/.local/bin/mise"

if [ ! -x "$MISE" ]; then
  echo "mise not found at $MISE, skipping tool install."
  exit 1
fi

# Source GitHub token so vfox/mise backends can make authenticated API calls
# (avoids 403s from unauthenticated GitHub release fetches on rate-limited machines)
if [ -f "$HOME/.config/private_env_tokens.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/.config/private_env_tokens.sh"
fi

echo "installing mise tools..."
"$MISE" install

echo "mise tools installed."

# rebuild bat theme cache (bat may have just been installed)
if command -v bat &>/dev/null; then
  echo "Rebuilding bat theme cache..."
  bat cache --build
fi
