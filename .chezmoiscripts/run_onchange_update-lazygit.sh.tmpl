#!/bin/bash

# ------------------------------------------
# update > lazygit (linux)
# bump the tag below to trigger an update:
# v1 (2026-03-28)
# ------------------------------------------

{{- if eq .chezmoi.os "linux" }}

if ! command -v git &>/dev/null; then
  echo "git not found, skipping lazygit install."
  exit 0
fi

echo "installing latest lazygit..."

LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": *"\K[^"]*')
ARCH=$(uname -m)
[ "$ARCH" = "aarch64" ] && ARCH="arm64" || ARCH="x86_64"

curl -Lo /tmp/lazygit.tar.gz \
  "https://github.com/jesseduffield/lazygit/releases/download/${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION#v}_Linux_${ARCH}.tar.gz"
tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
install /tmp/lazygit -D -t "$HOME/.local/bin/"
rm -f /tmp/lazygit.tar.gz /tmp/lazygit

echo "lazygit ${LAZYGIT_VERSION} installed."
{{- end }}
